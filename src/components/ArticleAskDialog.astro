---
import { useTranslations } from '../i18n';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale).articleAskDialog;
---

<dialog
  class="ask-dialog"
  id="article-ask-dialog"
  data-msg-success={t.success}
  data-msg-error={t.error}
  data-subtitle-default={t.subtitleDefault}
  data-subtitle-with-topic={t.subtitleWithTopic}
  data-hidden-subject-template={t.hiddenSubject}
  aria-labelledby="article-ask-dialog-title"
>
  <form
    class="ask-dialog-form"
    action="https://formspree.io/f/movnynen"
    method="POST"
  >
    <header class="ask-dialog-header">
      <h2 id="article-ask-dialog-title" class="ask-dialog-title">{t.title}</h2>
      <button
        type="button"
        class="ask-dialog-close"
        aria-label={t.closeAria}
        data-ask-close
      >
        <span class="material-symbols-rounded" aria-hidden="true">close</span>
      </button>
    </header>

    <p class="ask-dialog-subtitle" id="article-ask-dialog-subtitle">
      {t.subtitleDefault}
    </p>

    <input type="hidden" name="_subject" value={t.hiddenSubject} data-ask-subject />
    <input type="hidden" name="article" value="" data-ask-article />
    <input type="hidden" name="page_url" value="" data-ask-page />

    <div class="ask-dialog-field">
      <label for="ask-name" class="ask-dialog-label">{t.nameLabel}</label>
      <input
        id="ask-name"
        type="text"
        name="name"
        placeholder={t.namePlaceholder}
        class="ask-dialog-input"
        required
        autocomplete="name"
      />
    </div>

    <div class="ask-dialog-field">
      <label for="ask-email" class="ask-dialog-label">{t.emailLabel}</label>
      <input
        id="ask-email"
        type="email"
        name="email"
        placeholder={t.emailPlaceholder}
        class="ask-dialog-input"
        required
        autocomplete="email"
      />
    </div>

    <div class="ask-dialog-field">
      <label for="ask-message" class="ask-dialog-label">{t.messageLabel}</label>
      <textarea
        id="ask-message"
        name="message"
        placeholder={t.messagePlaceholder}
        class="ask-dialog-input ask-dialog-textarea"
        required
        rows="4"
      ></textarea>
    </div>

    <div class="ask-dialog-status" role="status" aria-live="polite" data-ask-status></div>

    <footer class="ask-dialog-actions">
      <button type="button" class="ask-dialog-btn ask-dialog-btn--ghost" data-ask-close>
        {t.cancel}
      </button>
      <button
        type="submit"
        class="ask-dialog-btn ask-dialog-btn--primary"
        data-ask-submit
        data-label={t.submit}
        data-sending={t.sending}
      >
        {t.submit}
      </button>
    </footer>
  </form>
</dialog>

<script>
  const dlg = document.getElementById('article-ask-dialog') as HTMLDialogElement | null;
  if (dlg) {
    const subtitleEl = dlg.querySelector<HTMLElement>('#article-ask-dialog-subtitle');
    const subjectInput = dlg.querySelector<HTMLInputElement>('[data-ask-subject]');
    const articleInput = dlg.querySelector<HTMLInputElement>('[data-ask-article]');
    const pageInput = dlg.querySelector<HTMLInputElement>('[data-ask-page]');
    const statusEl = dlg.querySelector<HTMLElement>('[data-ask-status]');
    const submitBtn = dlg.querySelector<HTMLButtonElement>('[data-ask-submit]');
    const form = dlg.querySelector<HTMLFormElement>('form');

    const subtitleDefault = dlg.dataset.subtitleDefault ?? '';
    const subtitleWithTopic = dlg.dataset.subtitleWithTopic ?? '';
    const subjectTpl = dlg.dataset.hiddenSubjectTemplate ?? '';
    const msgSuccess = dlg.dataset.msgSuccess ?? '';
    const msgError = dlg.dataset.msgError ?? '';

    document.querySelectorAll<HTMLButtonElement>('[data-ask-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const article = btn.dataset.askArticle ?? '';
        const topic = btn.dataset.askTopic ?? '';

        if (subtitleEl) {
          subtitleEl.textContent = topic && subtitleWithTopic
            ? subtitleWithTopic.replace('{topic}', topic)
            : subtitleDefault;
        }
        if (articleInput) articleInput.value = article;
        if (subjectInput) subjectInput.value = subjectTpl.replace('{article}', article || 'blog');
        if (pageInput) pageInput.value = window.location.href;
        if (statusEl) {
          statusEl.textContent = '';
          statusEl.dataset.state = '';
        }

        dlg.showModal();
        const firstInput = dlg.querySelector<HTMLInputElement>('#ask-name');
        firstInput?.focus();
      });
    });

    dlg.querySelectorAll<HTMLButtonElement>('[data-ask-close]').forEach((b) =>
      b.addEventListener('click', () => dlg.close())
    );

    // Click on backdrop closes
    dlg.addEventListener('click', (e) => {
      if (e.target === dlg) dlg.close();
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn) return;
      const original = submitBtn.dataset.label ?? submitBtn.textContent ?? '';
      const sending = submitBtn.dataset.sending ?? 'Sending…';
      submitBtn.disabled = true;
      submitBtn.textContent = sending;
      if (statusEl) statusEl.textContent = '';

      try {
        const fd = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: fd,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          if (statusEl) {
            statusEl.textContent = msgSuccess;
            statusEl.dataset.state = 'success';
          }
          form.reset();
          (window as any).umami?.track?.('cta-blog-ask-submit', {
            article: articleInput?.value ?? '',
          });
          setTimeout(() => dlg.close(), 1800);
        } else {
          throw new Error('Formspree responded ' + res.status);
        }
      } catch {
        if (statusEl) {
          statusEl.textContent = msgError;
          statusEl.dataset.state = 'error';
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = original;
      }
    });
  }
</script>

<style>
  .ask-dialog {
    border: none;
    border-radius: 16px;
    margin: auto;
    padding: 0;
    max-width: 32rem;
    width: calc(100% - 2rem);
    max-height: calc(100% - 3rem);
    background: var(--md-sys-color-surface, #fefbff);
    color: var(--md-sys-color-on-surface, #1c1b1f);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.18);
    font-family: 'Inter', sans-serif;
    overflow: auto;
  }

  .ask-dialog::backdrop {
    background: rgba(28, 27, 31, 0.55);
    backdrop-filter: blur(4px);
  }

  .ask-dialog[open] {
    animation: ask-dialog-in 0.18s ease-out;
  }

  @keyframes ask-dialog-in {
    from {
      opacity: 0;
      transform: translateY(6px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .ask-dialog-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem 1.5rem 1.25rem;
  }

  .ask-dialog-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .ask-dialog-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.2;
    margin: 0;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    letter-spacing: -0.015em;
  }

  .ask-dialog-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 8px;
    color: var(--md-sys-color-on-surface-variant, #5f6368);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s, color 0.15s;
  }

  .ask-dialog-close:hover {
    background-color: var(--md-sys-color-surface-variant, #e7e0ec);
    color: var(--md-sys-color-on-surface, #1c1b1f);
  }

  .ask-dialog-subtitle {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--md-sys-color-on-surface-variant, #49454f);
    margin: 0 0 0.25rem;
  }

  .ask-dialog-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .ask-dialog-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    letter-spacing: 0.01em;
  }

  .ask-dialog-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    font-family: inherit;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    background-color: var(--md-sys-color-surface, #fefbff);
    border: 1px solid var(--md-sys-color-outline, #79747e);
    border-radius: 8px;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }

  .ask-dialog-input:focus {
    outline: none;
    border-color: var(--md-sys-color-primary, #6750a4);
    box-shadow: 0 0 0 3px rgba(103, 80, 164, 0.15);
  }

  .ask-dialog-textarea {
    resize: vertical;
    min-height: 5.5rem;
    font-family: inherit;
  }

  .ask-dialog-status {
    font-size: 0.875rem;
    line-height: 1.4;
    min-height: 1.2em;
  }

  .ask-dialog-status[data-state='success'] {
    color: #1f6e3a;
  }

  .ask-dialog-status[data-state='error'] {
    color: #b3261e;
  }

  .ask-dialog-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.625rem;
    margin-top: 0.25rem;
  }

  .ask-dialog-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.125rem;
    border-radius: 9px;
    font-family: inherit;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s, box-shadow 0.15s;
    line-height: 1.2;
  }

  .ask-dialog-btn--ghost {
    background: none;
    border: 1px solid transparent;
    color: var(--md-sys-color-on-surface-variant, #5f6368);
  }

  .ask-dialog-btn--ghost:hover {
    background-color: var(--md-sys-color-surface-variant, #e7e0ec);
    color: var(--md-sys-color-on-surface, #1c1b1f);
  }

  .ask-dialog-btn--primary {
    background-color: var(--md-sys-color-primary, #6750a4);
    color: var(--md-sys-color-on-primary, #ffffff);
    border: 1px solid transparent;
  }

  .ask-dialog-btn--primary:hover:not(:disabled) {
    background-color: #594092;
    box-shadow: 0 4px 14px rgba(103, 80, 164, 0.3);
  }

  .ask-dialog-btn--primary:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  @media (max-width: 540px) {
    .ask-dialog {
      width: calc(100% - 1rem);
      max-height: calc(100% - 2rem);
    }
    .ask-dialog-form {
      padding: 1.25rem 1.125rem 1rem;
    }
    .ask-dialog-title {
      font-size: 1.25rem;
    }
    .ask-dialog-actions {
      flex-direction: column-reverse;
    }
    .ask-dialog-btn {
      width: 100%;
    }
  }

  /* Dark mode — warm orange palette */
  :global(html[data-theme='dark']) .ask-dialog {
    background: #1a1815;
    color: #f5f0ea;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
  }

  :global(html[data-theme='dark']) .ask-dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-title {
    color: #f5f0ea;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-subtitle {
    color: #d5c3b5;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-label {
    color: #f5f0ea;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-input {
    background-color: #221d18;
    color: #f5f0ea;
    border-color: rgba(255, 184, 111, 0.25);
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-input:focus {
    border-color: #FFB86F;
    box-shadow: 0 0 0 3px rgba(255, 184, 111, 0.2);
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-input::placeholder {
    color: #a89b8c;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-close {
    color: #d5c3b5;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-close:hover {
    background-color: rgba(255, 184, 111, 0.08);
    color: #FFB86F;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-btn--ghost {
    color: #d5c3b5;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-btn--ghost:hover {
    background-color: rgba(255, 184, 111, 0.08);
    color: #FFB86F;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-btn--primary {
    background-color: #FFB86F;
    color: #1a1815;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-btn--primary:hover:not(:disabled) {
    background-color: #ffc98f;
    box-shadow: 0 4px 18px rgba(255, 184, 111, 0.3);
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-status[data-state='success'] {
    color: #7fce9c;
  }

  :global(html[data-theme='dark']) .ask-dialog .ask-dialog-status[data-state='error'] {
    color: #ff9d96;
  }
</style>
