---
/**
 * HrefLang - Generates <link rel="alternate" hreflang="..."> tags.
 *
 * For blog pages, only emits hreflang for locales where the content actually
 * exists in the collection (prevents 404 alternates).
 * For other pages, emits all locales (assumes all static pages exist).
 */
import { getCollection } from 'astro:content';
import { buildPublicUrl, LOCALES, type Locale } from '../lib/public-url';

export interface Props {
  siteUrl?: string;
}

const { siteUrl } = Astro.props;
const BLOG_SLUG_GROUPS: Array<Record<Locale, string>> = [];

const pathname = Astro.url.pathname;

function getBlogSlugGroup(slug: string): Record<Locale, string> | undefined {
  return BLOG_SLUG_GROUPS.find((group) => Object.values(group).includes(slug));
}

// Strip locale prefix to get the base path
const localeStripped = pathname.replace(/^\/(fr|zh-TW|zh)(\/|$)/, '/');
const basePath = localeStripped === '' ? '/' : localeStripped;

// For blog pages: only declare alternates for locales that have this slug
const blogMatch = basePath.match(/^\/blog\/(.+?)\/?\s*$/);
let activeLocales: readonly Locale[] = LOCALES;
let blogPathForLocale = (locale: Locale) => `/blog/${blogMatch?.[1] ?? ''}`;

if (blogMatch) {
  const slug = blogMatch[1];
  const slugGroup = getBlogSlugGroup(slug);
  const allBlogPosts = await getCollection('blog', ({ data }) => !data.draft);
  const existingLocales = LOCALES.filter((locale) => {
    const localizedSlug = slugGroup?.[locale] ?? slug;
    const prefix = locale === 'en' ? 'en' : locale;
    return allBlogPosts.some((post) => post.id === `${prefix}/${localizedSlug}.mdx` || post.id === `${prefix}/${localizedSlug}.md`);
  });
  activeLocales = existingLocales.length > 0 ? existingLocales : LOCALES;
  blogPathForLocale = (locale: Locale) => `/blog/${slugGroup?.[locale] ?? slug}`;
}
---

{activeLocales.map((locale) => (
  <link
    rel="alternate"
    hreflang={locale}
    href={buildPublicUrl(blogMatch ? blogPathForLocale(locale) : pathname, locale, siteUrl)}
  />
))}
{activeLocales.includes('en')
  ? <link rel="alternate" hreflang="x-default" href={buildPublicUrl(blogMatch ? blogPathForLocale('en') : pathname, 'en', siteUrl)} />
  : <link rel="alternate" hreflang="x-default" href={buildPublicUrl(blogMatch ? blogPathForLocale(activeLocales[0]) : pathname, activeLocales[0], siteUrl)} />
}
