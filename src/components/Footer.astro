---
import { useTranslations } from '../i18n';

export interface Props {
  variant?: 'main' | 'subsite';
}

const { variant = 'main' } = Astro.props;
const isSubsite = variant === 'subsite';
const locale = (Astro as any).currentLocale ?? 'en';
const currentYear = new Date().getFullYear();
const t = useTranslations(locale).footer;

const homeHref = isSubsite ? 'https://casys.ai' : (locale === 'en' ? '/' : `/${locale}/`);
const basePath = isSubsite ? 'https://casys.ai' : homeHref.replace(/\/$/, '');
const projectsHref = `${basePath}/use-cases`;
const contactHref = `${isSubsite ? 'https://casys.ai/' : homeHref}#contact`;
const extAttrs = isSubsite ? { target: '_blank' as const, rel: 'noopener' } : {};
---

<footer id="footer" class:list={[isSubsite && 'footer--subsite']}>
  <div class="footer-container">
    <!-- Main Grid -->
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href={homeHref} class="brand-link" {...extAttrs}>
          <img src="/icons/logo.svg" alt="Casys" class="brand-logo" />
          <span class="brand-name">Casys</span>
        </a>
        <p class="brand-description">{t.description}</p>
        <p class="brand-tagline">{t.tagline}</p>
      </div>

      <!-- Navigation Columns -->
      <div class="footer-nav">
        <div class="nav-column">
          <h3 class="nav-title">{t.product}</h3>
          <nav class="nav-links" aria-label={t.product}>
            <a href={projectsHref} {...extAttrs}>{t.projects}</a>
            <a href={contactHref} {...extAttrs}>{t.consulting}</a>
            <a href={contactHref} {...extAttrs}>{t.training}</a>
          </nav>
        </div>

        <div class="nav-column">
          <h3 class="nav-title">{t.openSource}</h3>
          <nav class="nav-links" aria-label={t.openSource}>
            <a href={`${basePath}/mcp-platform`} {...extAttrs}>MCP Platform</a>
            <a href={`${basePath}/mcp-std`} {...extAttrs}>@casys/mcp-std</a>
            <a href={`${basePath}/use-cases/mcp-erpnext`} {...extAttrs}>MCP ERPNext</a>
            <a href={`${basePath}/use-cases/mcp-einvoice`} {...extAttrs}>MCP E-Invoice</a>
            <a href="https://jsr.io/@casys" target="_blank" rel="noopener" class="jsr-link">
              <svg class="jsr-icon" width="16" height="16" viewBox="0 -3 64 64" fill="none" aria-hidden="true">
                <path d="M 0,21.846 H 9.846 V 12 h 34.462 v 4.923 H 64 V 36.616 H 54.155 V 46.462 H 19.693 V 41.539 H 0" fill="#083344"/>
                <g fill="#f7df1e" transform="matrix(4.923,0,0,4.923,0,12)">
                  <path d="M 1,3 H 2 V 4 H 3 V 1 H 4 V 5 H 1"/>
                  <path d="M 5,1 H 8 V 2 H 6 V 3 H 8 V 6 H 5 V 5 H 7 V 4 H 5"/>
                  <path d="m 9,2 h 3 V 4 H 11 V 3 H 10 V 6 H 9"/>
                </g>
              </svg>
              JSR Packages
            </a>
          </nav>
        </div>

        <div class="nav-column">
          <h3 class="nav-title">{t.connect}</h3>
          <nav class="nav-links" aria-label={t.connect}>
            <a href={contactHref} {...extAttrs}>{t.contact}</a>
            <a href="https://discord.gg/fuPg8drR" target="_blank" rel="noopener">{t.discord}</a>
            <a href="https://github.com/Casys-AI" target="_blank" rel="noopener">GitHub</a>
            <a href="https://www.linkedin.com/company/casys-ai" target="_blank" rel="noopener">LinkedIn</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">&copy; {currentYear} Casys AI. {locale === 'fr' ? 'Tous droits réservés.' : locale === 'zh' ? '保留所有权利。' : locale === 'zh-TW' ? '保留所有權利。' : 'All rights reserved.'}</p>
      <div class="social-icons">
        <a href="https://github.com/Casys-AI" target="_blank" rel="noopener" aria-label="GitHub" class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/company/casys-ai" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ========================================
     FOOTER - Editorial/Refined Aesthetic
     Font: Fraunces for brand
     Clean, minimal, sophisticated
     ======================================== */

  footer {
    padding: 64px 0 32px;
    background: var(--md-sys-color-surface-container-low);
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Main Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: 64px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  /* Brand Section */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 8px;
  }

  .brand-link:focus-visible {
    outline: 2px solid var(--md-sys-color-primary);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .brand-logo {
    width: 22px;
    height: 22px;
  }

  .brand-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    letter-spacing: -0.02em;
  }

  .brand-description {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.5;
  }

  .brand-tagline {
    font-size: 0.85rem;
    color: #5e5962;
    margin: 0;
  }

  /* Navigation */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .nav-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .nav-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .nav-links a {
    font-size: 0.9rem;
    color: var(--md-sys-color-on-surface-variant);
    text-decoration: none;
    transition: color 200ms ease-out;
  }

  .nav-links a:hover {
    color: var(--md-sys-color-primary);
  }

  .nav-links a:focus-visible {
    outline: 2px solid var(--md-sys-color-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .jsr-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .jsr-icon {
    flex-shrink: 0;
    border-radius: 3px;
  }

  /* Bottom Bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
  }

  .copyright {
    font-size: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    opacity: 0.8;
  }

  .social-icons {
    display: flex;
    gap: 12px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--md-sys-color-on-surface-variant);
    border-radius: 8px;
    transition: color 200ms ease-out, background 200ms ease-out;
  }

  .social-icon:hover {
    color: var(--md-sys-color-primary);
    background: var(--md-sys-color-surface-container-high);
  }

  .social-icon:focus-visible {
    outline: 2px solid var(--md-sys-color-primary);
    outline-offset: 3px;
  }

  .social-icon svg {
    width: 20px;
    height: 20px;
  }

  /* Tablet */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .footer-nav {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    footer {
      padding: 48px 0 24px;
    }

    .footer-grid {
      gap: 32px;
    }

    .footer-nav {
      grid-template-columns: 1fr 1fr;
      gap: 24px 16px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }

  /* Very small screens (390px and below) */
  @media (max-width: 420px) {
    .footer-nav {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  /* ========================================
     SUBSITE VARIANT - Color overrides
     Hardcoded #5e5962 for light mode
     ======================================== */

  .footer--subsite .brand-description,
  .footer--subsite .brand-tagline,
  .footer--subsite .nav-links a,
  .footer--subsite .social-icon {
    color: #5e5962;
  }

  .footer--subsite .copyright {
    color: #5e5962;
    opacity: 1;
  }

  @media (max-width: 600px) {
    .footer--subsite .footer-nav {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
    }
  }

  @media (max-width: 420px) {
    .footer--subsite .footer-nav {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
    }
  }
</style>

<style is:global>
  /* ========================================
     FOOTER - DARK MODE
     Warm orange palette (#FFB86F, #D4A574)
     ======================================== */

  html[data-theme="dark"] #footer {
    background: #0a0908;
    border-top-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #footer .footer-grid {
    border-bottom-color: rgba(255, 184, 111, 0.1);
  }


  html[data-theme="dark"] #footer .brand-name {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #footer .brand-description {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .brand-tagline {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .nav-title {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #footer .nav-links a {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .nav-links a:hover {
    color: #FFB86F;
  }

  html[data-theme="dark"] #footer .brand-link:focus-visible,
  html[data-theme="dark"] #footer .nav-links a:focus-visible,
  html[data-theme="dark"] #footer .social-icon:focus-visible {
    outline-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #footer .copyright {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .social-icon {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .social-icon:hover {
    color: #FFB86F;
    background: rgba(255, 184, 111, 0.1);
  }
</style>
