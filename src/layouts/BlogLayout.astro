    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
    color: var(--md-sys-color-on-surface-variant, #57534e);
    user-select: none;
  }

  /* --- Main Content Area --- */
  .blog-main {
    flex: 1;
    overflow-y: auto;
    background-color: var(--md-sys-color-surface, #fafaf9);

    /* Auto-hide scrollbar — visible only on hover or while actively scrolling */
    scrollbar-width: none;
    scrollbar-color: rgba(0, 0, 0, 0.18) transparent;
  }

  .blog-main:hover,
  .blog-main.is-scrolling {
    scrollbar-width: thin;
  }

  .blog-main::-webkit-scrollbar {
    width: 0;
    background: transparent;
    transition: width 0.2s ease;
  }

  .blog-main:hover::-webkit-scrollbar,
  .blog-main.is-scrolling::-webkit-scrollbar {
    width: 6px;
  }

  .blog-main::-webkit-scrollbar-track {
    background: transparent;
  }

  .blog-main::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.18);
    border-radius: 999px;
  }

  .blog-content {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  /* --- Sidebar Toggle Button (mobile drawer + desktop expand) --- */
  .blog-sidebar-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: none;
    border-radius: 8px;
    background: none;
    color: var(--md-sys-color-on-surface, #1c1917);
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .blog-sidebar-toggle:hover {
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
  }

  /* --- Sidebar Close Button (mobile only) --- */
  .blog-sidebar-close {
    display: none;
    position: absolute;
    top: 14px;
    right: 12px;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: none;
    border-radius: 8px;
    background: none;
    color: var(--md-sys-color-on-surface-variant, #78716c);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
    z-index: 1;
  }

  .blog-sidebar-close:hover {
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
    color: var(--md-sys-color-on-surface, #1c1917);
  }

  /* --- Sidebar Overlay (mobile) --- */
  .blog-sidebar-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 49;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .blog-sidebar-overlay--visible {
    opacity: 1;
  }

  /* --- Responsive: Mobile (< 768px) --- */
  @media (max-width: 767px) {
    .blog-sidebar-toggle {
      display: flex;
    }

    .blog-sidebar-close {
      display: flex;
    }

    .blog-sidebar-overlay {
      display: block;
      pointer-events: none;
    }

    .blog-sidebar-overlay--visible {
      pointer-events: auto;
    }

    .blog-sidebar-collapse,
    .blog-sidebar-strip,
    .blog-toc {
      display: none !important;
    }

    /* Hide redundant "← Home" link on mobile — clickable CASYS brand replaces it */
    .blog-topnav-links .blog-topnav-link {
      display: none;
    }

    /* Show floating TOC button on mobile (article pages only — JS removes [hidden]) */
    .blog-toc-fab:not([hidden]) {
      display: inline-flex;
    }

    /* Show reading progress bar on mobile (desktop has the TOC sidebar) */
    .reading-progress {
      display: block;
    }

    .blog-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 50;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      box-shadow: none;
      width: 300px !important;
      min-width: 300px !important;
      opacity: 1;
      pointer-events: auto;
    }

    .blog-sidebar-content {
      display: flex !important;
    }

    .blog-sidebar--open {
      transform: translateX(0);
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.15);
    }

    .blog-content {
      padding: 1.5rem 1rem;
    }

    .blog-body {
      overflow: auto;
    }

    .blog-shell {
      flex-direction: column;
      height: auto;
      min-height: calc(100vh - 60px);
    }

    .blog-main {
      overflow: visible;
    }
  }
</style>

