---
import '../styles.css';
import '../styles/fonts.css';
import Analytics from '@vercel/analytics/astro';
import { getCollection } from 'astro:content';
import HrefLang from '../components/HrefLang.astro';
import { DEFAULT_SITE_URL, resolvePublicUrl } from '../lib/public-url';

export interface Props {
  title: string;
  locale?: 'en' | 'fr' | 'zh' | 'zh-TW';
  description?: string;
  slug?: string;
  ogTitle?: string;
  ogDescription?: string;
  datePublished?: string;
  dateModified?: string;
  author?: string;
  tags?: string[];
  category?: string;
}

const { title, locale = 'en', description, slug, ogTitle, ogDescription, datePublished, dateModified, author, tags, category } = Astro.props;
const effectiveOgTitle = ogTitle || title;
const effectiveOgDescription = ogDescription || description;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL as string | undefined)?.trim();
const rootSiteUrl = (siteUrl || DEFAULT_SITE_URL).replace(/\/+$/, '');
const pathname = Astro.url.pathname;
const publicUrl = resolvePublicUrl(pathname, siteUrl);
const ogImage = slug
  ? new URL(`/og/blog/${slug}.png`, publicUrl.origin).toString()
  : new URL('/og/home.png?v=20260311-integrator', publicUrl.origin).toString();
const localePrefix = locale === 'en' ? '' : `/${locale}`;
const canonicalUrl = publicUrl.canonicalUrl;
const blogBaseUrl = `${rootSiteUrl}${localePrefix}/blog`;

const labels = {
  en: {
    blogTitle: 'CASYS Blog',
    blogSubtitle: 'Articles and insights on CASYS development.',
    allArticles: 'All articles',
    recentArticles: 'Recent articles',
    byCategory: 'By category',
    popularTags: 'Popular tags',
    search: 'Search',
    subscribe: 'Subscribe to updates',
    home: 'Home',
    others: 'others',
    general: 'General',
    toc: 'On this page',
  },
  fr: {
    blogTitle: 'Blog CASYS',
    blogSubtitle: 'Articles et actualités sur le développement de CASYS.',
    allArticles: 'Tous les articles',
    recentArticles: 'Articles récents',
    byCategory: 'Par catégorie',
    popularTags: 'Tags populaires',
    search: 'Rechercher',
    subscribe: "S'abonner aux nouveautés",
    home: 'Accueil',
    others: 'autres',
    general: 'Général',
    toc: 'Sur cette page',
  },
  zh: {
    blogTitle: 'CASYS 博客',
    blogSubtitle: 'CASYS 开发相关文章与动态。',
    allArticles: '所有文章',
    recentArticles: '最新文章',
    byCategory: '按类别',
    popularTags: '热门标签',
    search: '搜索',
    subscribe: '订阅更新',
    home: '首页',
    others: '更多',
    general: '通用',
    toc: '本页目录',
  },
  'zh-TW': {
    blogTitle: 'CASYS 部落格',
    blogSubtitle: 'CASYS 開發相關文章與動態。',
    allArticles: '所有文章',
    recentArticles: '最新文章',
    byCategory: '按類別',
    popularTags: '熱門標籤',
    search: '搜尋',
    subscribe: '訂閱更新',
    home: '首頁',
    others: '更多',
    general: '通用',
    toc: '本頁目錄',
  },
};

const t = labels[locale];
const blogBase = locale === 'en' ? '/blog' : `/${locale}/blog`;
const homeBase = locale === 'en' ? '/' : `/${locale}`;

// Récupérer les articles de blog pour la navigation (filtrés par locale)
const blogPosts = await getCollection('blog', ({ data, id }) => {
  return !data.draft && id.startsWith(`${locale}/`);
});

// Trier par date de publication (plus récent en premier)
const sortedPosts = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Articles récents (5 derniers)
const recentPosts = sortedPosts.slice(0, 5);

// Grouper par catégorie
const postsByCategory = sortedPosts.reduce((acc, post) => {
  const category = post.data.category || t.general;
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof sortedPosts>);

// Tags populaires
const allTags = sortedPosts.flatMap(post => post.data.tags);
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const popularTags = Object.entries(tagCounts)
  .sort(([,a], [,b]) => b - a)
  .slice(0, 10)
  .map(([tag]) => tag);

const currentPath = Astro.url.pathname;

// Helper to get slug without locale prefix
function getPostSlug(post: typeof sortedPosts[0]) {
  return post.slug.replace(new RegExp(`^${locale}/`, 'i'), '');
}
---

<!DOCTYPE html>
<html lang={locale === 'zh' ? 'zh-CN' : locale === 'zh-TW' ? 'zh-TW' : locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description || t.blogSubtitle} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />

    <!-- Self-hosted fonts (Vercel CDN) — preload critical display font -->
    <link rel="preload" href="/fonts/fraunces-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Material Symbols — icon font, kept external (not critical path) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />

    <script>
      // Auto theme sync with system preference
      (function() {
        try {
          var root = document.documentElement;
          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          var apply = function() {
            root.dataset.theme = mql.matches ? 'dark' : 'light';
          };
          apply();
          mql.addEventListener('change', apply);
        } catch(_) {}
      })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FR86NHGK8Y"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FR86NHGK8Y', {
        cookie_domain: 'casys.ai',
        linker: { accept_incoming: false, decorate: false }
      });
    </script>

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <HrefLang siteUrl={siteUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Casys AI" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={effectiveOgTitle} />
    {effectiveOgDescription && <meta property="og:description" content={effectiveOgDescription} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={effectiveOgTitle} />
    {effectiveOgDescription && <meta name="twitter:description" content={effectiveOgDescription} />}
    <meta name="twitter:image" content={ogImage} />
    <script defer src="/u/script.js" data-website-id="41fe387f-874e-4c5b-8a69-1364587b77f5"></script>
    {slug && blogBaseUrl && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description || t.blogSubtitle,
        ...(siteUrl && { "image": ogImage }),
        ...(datePublished && { "datePublished": datePublished }),
        ...(dateModified && { "dateModified": dateModified }),
        "author": author
          ? { "@type": "Person", "name": author, "url": `${rootSiteUrl}/about` }
          : { "@type": "Organization", "name": "Casys AI", "url": rootSiteUrl },
        "publisher": {
          "@type": "Organization",
          "name": "Casys AI",
          "url": rootSiteUrl,
          "logo": {
            "@type": "ImageObject",
            "url": `${rootSiteUrl}/icons/logo.svg`
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalUrl || `${blogBaseUrl}/${slug}`
        },
        ...(tags?.length && { "keywords": tags.join(", ") }),
        ...(category && { "articleSection": category }),
        "inLanguage": locale === 'zh' ? 'zh-CN' : locale
      }).replace(/</g, '\\u003c')} />
    )}
    {slug && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": t.home, "item": `${rootSiteUrl}${localePrefix || '/'}` },
          { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${rootSiteUrl}${localePrefix}/blog` },
          { "@type": "ListItem", "position": 3, "name": title }
        ]
      }).replace(/</g, '\\u003c')} />
    )}
  </head>

  <body class="blog-body">
    <!-- Nav bar -->
    <nav class="blog-topnav" aria-label="Blog navigation">
      <div class="blog-topnav-inner">
        <!-- Mobile sidebar toggle -->
        <button class="blog-sidebar-toggle" aria-label="Toggle sidebar" id="sidebarToggle">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="3" y1="5" x2="17" y2="5" />
            <line x1="3" y1="10" x2="17" y2="10" />
            <line x1="3" y1="15" x2="17" y2="15" />
          </svg>
        </button>

        <!-- Logo + title -->
        <a href={homeBase} class="blog-topnav-brand" aria-label={t.home}>
          <img src="/icons/favicon-32x32.png" alt="CASYS" class="blog-topnav-logo" />
          <span class="blog-topnav-name">CASYS</span>
          <span class="blog-topnav-label">Blog</span>
        </a>

        <!-- Navigation links -->
        <div class="blog-topnav-links">
          <a href={homeBase} class="blog-topnav-link">&larr; {t.home}</a>
          <a href="https://github.com/Casys-AI" target="_blank" rel="noopener" aria-label="GitHub" class="blog-topnav-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://discord.gg/VruRCTS8pQ" target="_blank" rel="noopener" aria-label="Discord" class="blog-topnav-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/casys-ai" target="_blank" rel="noopener" aria-label="LinkedIn" class="blog-topnav-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>
      <div class="reading-progress" id="readingProgress" aria-hidden="true"></div>
    </nav>

    <!-- Main layout: sidebar + content -->
    <div class:list={['blog-shell', { 'blog-shell--collapsed': !!slug }]}>
      <!-- Sidebar overlay (mobile) -->
      <div class="blog-sidebar-overlay" id="sidebarOverlay"></div>

      <!-- Sidebar -->
      <aside class="blog-sidebar" id="blogSidebar">
        <!-- Collapsed strip (40px, shown when sidebar collapsed) -->
        <div class="blog-sidebar-strip" id="sidebarStrip">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </div>
        <!-- Mobile close -->
        <button class="blog-sidebar-close" id="sidebarClose" aria-label="Close sidebar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="4" x2="14" y2="14" />
            <line x1="14" y1="4" x2="4" y2="14" />
          </svg>
        </button>
        <!-- Sidebar content (hidden when collapsed) -->
        <div class="blog-sidebar-content">
        <div class="blog-sidebar-header">
          <div class="blog-sidebar-header-top">
            <h2 class="blog-sidebar-title">{t.blogTitle}</h2>
            <button class="blog-sidebar-collapse" id="sidebarCollapse" aria-label="Hide sidebar">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1.5" y="2.5" width="13" height="11" rx="1.5"/>
                <line x1="6" y1="2.5" x2="6" y2="13.5"/>
                <polyline points="10.5,6.5 8.5,8 10.5,9.5"/>
              </svg>
            </button>
          </div>
          <p class="blog-sidebar-subtitle">{t.blogSubtitle}</p>
        </div>

        <nav class="blog-sidebar-nav" aria-label="Blog navigation">
          <!-- All articles link -->
          <div class="blog-nav-section">
            <a
              href={blogBase}
              class:list={[
                'blog-nav-link',
                { 'blog-nav-link--active': currentPath === blogBase || currentPath === `${blogBase}/` }
              ]}
            >
              {t.allArticles}
            </a>
          </div>

          <!-- Recent articles -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.recentArticles}</h3>
            <ul class="blog-nav-list">
              {recentPosts.map((post) => (
                <li>
                  <a
                    href={`${blogBase}/${getPostSlug(post)}`}
                    class:list={[
                      'blog-nav-link blog-nav-link--article',
                      { 'blog-nav-link--active': currentPath === `${blogBase}/${getPostSlug(post)}` }
                    ]}
                  >
                    <span class="blog-nav-link-title">{post.data.title}</span>
                    <span class="blog-nav-link-meta">
                      <span>{post.data.date.toLocaleDateString(locale === 'zh' ? 'zh-CN' : locale === 'zh-TW' ? 'zh-TW' : locale)}</span>
                      {post.data.category && (
                        <>
                          <span class="blog-nav-link-dot">&middot;</span>
                          <span>{post.data.category}</span>
                        </>
                      )}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Categories -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.byCategory}</h3>
            <ul class="blog-nav-list">
              {Object.entries(postsByCategory).map(([categoryName, posts]) => (
                <li>
                  <div class="blog-category-row">
                    <span class="blog-category-name">{categoryName}</span>
                    <span class="blog-category-count">{posts.length}</span>
                  </div>
                  <ul class="blog-category-posts">
                    {posts.slice(0, 3).map((post) => (
                      <li>
                        <a
                          href={`${blogBase}/${getPostSlug(post)}`}
                          class:list={[
                            'blog-nav-link blog-nav-link--sub',
                            { 'blog-nav-link--active': currentPath === `${blogBase}/${getPostSlug(post)}` }
                          ]}
                        >
                          <span class="blog-nav-link-title">{post.data.title}</span>
                        </a>
                      </li>
                    ))}
                    {posts.length > 3 && (
                      <>
                        {posts.slice(3).map((post) => (
                          <li class="blog-category-overflow">
                            <a
                              href={`${blogBase}/${getPostSlug(post)}`}
                              class:list={[
                                'blog-nav-link blog-nav-link--sub',
                                { 'blog-nav-link--active': currentPath === `${blogBase}/${getPostSlug(post)}` }
                              ]}
                            >
                              <span class="blog-nav-link-title">{post.data.title}</span>
                            </a>
                          </li>
                        ))}
                        <li>
                          <button class="blog-category-toggle" data-count={posts.length - 3} data-others={t.others}>
                            +{posts.length - 3} {t.others}
                          </button>
                        </li>
                      </>
                    )}
                  </ul>
                </li>
              ))}
            </ul>
          </div>

          <!-- Popular tags -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.popularTags}</h3>
            <div class="blog-tags">
              {popularTags.map((tag) => (
                <span class="blog-tag">#{tag}</span>
              ))}
            </div>
          </div>

          <!-- Actions -->
        </nav>
        </div><!-- /.blog-sidebar-content -->
      </aside>

      <!-- Main content -->
      <main class="blog-main" id="blogMain">
        <div class="blog-content">
          <slot />
        </div>
      </main>

      <!-- Table of Contents (visible when sidebar collapsed) -->
      <aside class="blog-toc" id="blogToc">
        <div class="blog-toc-inner">
          <div class="blog-toc-header">
            <span class="blog-toc-label">{t.toc}</span>
          </div>
          <nav class="blog-toc-nav" id="blogTocNav" aria-label="Article navigation"></nav>
        </div>
      </aside>
    </div>

    <!-- Mobile TOC: floating button + bottom sheet (article pages only) -->
    <button class="blog-toc-fab" id="blogTocFab" aria-label={t.toc} aria-expanded="false" aria-controls="blogTocSheet" hidden>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="8" y1="6" x2="21" y2="6"></line>
        <line x1="8" y1="12" x2="21" y2="12"></line>
        <line x1="8" y1="18" x2="21" y2="18"></line>
        <circle cx="4" cy="6" r="1.2" fill="currentColor"></circle>
        <circle cx="4" cy="12" r="1.2" fill="currentColor"></circle>
        <circle cx="4" cy="18" r="1.2" fill="currentColor"></circle>
      </svg>
    </button>
    <div class="blog-toc-sheet-overlay" id="blogTocSheetOverlay" hidden></div>
    <aside class="blog-toc-sheet" id="blogTocSheet" role="dialog" aria-modal="true" aria-label={t.toc} hidden>
      <div class="blog-toc-sheet-header">
        <span class="blog-toc-label">{t.toc}</span>
        <button class="blog-toc-sheet-close" id="blogTocSheetClose" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>
      <nav class="blog-toc-sheet-nav" id="blogTocSheetNav" aria-label="Article navigation"></nav>
    </aside>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('sidebarToggle');
        const close = document.getElementById('sidebarClose');
        const collapse = document.getElementById('sidebarCollapse');
        const strip = document.getElementById('sidebarStrip');
        const sidebar = document.getElementById('blogSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const shell = document.querySelector('.blog-shell');
        if (!toggle || !close || !sidebar || !overlay || !collapse || !strip || !shell) return;

        // Mobile drawer
        function open() {
          sidebar.classList.add('blog-sidebar--open');
          overlay.classList.add('blog-sidebar-overlay--visible');
          document.body.style.overflow = 'hidden';
        }
        function shut() {
          sidebar.classList.remove('blog-sidebar--open');
          overlay.classList.remove('blog-sidebar-overlay--visible');
          document.body.style.overflow = '';
        }
        toggle.addEventListener('click', open);
        close.addEventListener('click', shut);
        overlay.addEventListener('click', shut);

        // Desktop collapse/expand (ExplorerSidebar pattern)
        // Blog index: sidebar open, no TOC, no collapse/strip
        // Article pages: sidebar collapsed, TOC visible
        const path = window.location.pathname.replace(/\/$/, '');
        const isBlogIndex = /^\/(fr|zh|zh-TW)?\/?(blog)?$/.test(path) || path.endsWith('/blog');
        const tocEl = document.getElementById('blogToc');

        if (isBlogIndex) {
          // Hide TOC, strip, and collapse button on index
          if (tocEl) tocEl.style.display = 'none';
          strip.style.display = 'none';
          collapse.style.display = 'none';
        } else {
          // Article: already collapsed via server-rendered class
          collapse.addEventListener('click', () => {
            shell.classList.add('blog-shell--collapsed');
          });

          strip.addEventListener('click', () => {
            shell.classList.remove('blog-shell--collapsed');
          });
        }

        // Build Table of Contents
        const tocNav = document.getElementById('blogTocNav');
        const tocNavMobile = document.getElementById('blogTocSheetNav');
        const content = document.querySelector('.blog-content');
        const mainEl = document.getElementById('blogMain');
        if (!tocNav || !content || !mainEl) return;

        // Reading progress bar (article pages only)
        // Desktop scrolls .blog-main; mobile (<768px) scrolls window — listen to both.
        const progressBar = document.getElementById('readingProgress');
        if (progressBar && !isBlogIndex) {
          const updateProgress = () => {
            const isDesktop = window.matchMedia('(min-width: 768px)').matches;
            const top = isDesktop ? mainEl.scrollTop : (window.scrollY || document.documentElement.scrollTop);
            const max = isDesktop
              ? mainEl.scrollHeight - mainEl.clientHeight
              : document.documentElement.scrollHeight - window.innerHeight;
            const ratio = max > 0 ? Math.min(1, Math.max(0, top / max)) : 0;
            progressBar.style.width = (ratio * 100).toFixed(2) + '%';
          };
          mainEl.addEventListener('scroll', updateProgress, { passive: true });
          window.addEventListener('scroll', updateProgress, { passive: true });
          window.addEventListener('resize', updateProgress, { passive: true });
          updateProgress();
        }

        // Auto-hide article scrollbar (visible on hover + while scrolling)
        if (!isBlogIndex) {
          let scrollTimeout;
          const showScrollbar = () => {
            mainEl.classList.add('is-scrolling');
            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => mainEl.classList.remove('is-scrolling'), 1200);
          };
          mainEl.addEventListener('scroll', showScrollbar, { passive: true });
        }

        // Collect headings, stop at "related articles" boundary
        const stopWords = ['articles similaires', 'related articles', 'see also', '相关文章', '相關文章'];
        const allHeadings = content.querySelectorAll('h2, h3');
        const headings = [];
        for (const h of allHeadings) {
          const text = h.textContent.trim().toLowerCase();
          if (stopWords.some(sw => text.includes(sw))) break;
          headings.push(h);
        }
        if (headings.length === 0) return;

        // Mobile TOC sheet wiring
        const tocFab = document.getElementById('blogTocFab');
        const tocSheet = document.getElementById('blogTocSheet');
        const tocSheetOverlay = document.getElementById('blogTocSheetOverlay');
        const tocSheetClose = document.getElementById('blogTocSheetClose');
        const openSheet = () => {
          if (!tocSheet || !tocSheetOverlay || !tocFab) return;
          tocSheet.hidden = false;
          tocSheetOverlay.hidden = false;
          requestAnimationFrame(() => {
            tocSheet.classList.add('is-open');
            tocSheetOverlay.classList.add('is-open');
          });
          tocFab.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        };
        const closeSheet = () => {
          if (!tocSheet || !tocSheetOverlay || !tocFab) return;
          tocSheet.classList.remove('is-open');
          tocSheetOverlay.classList.remove('is-open');
          tocFab.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
          setTimeout(() => {
            tocSheet.hidden = true;
            tocSheetOverlay.hidden = true;
          }, 220);
        };
        if (!isBlogIndex && tocFab) {
          tocFab.hidden = false;
          tocFab.addEventListener('click', openSheet);
          if (tocSheetClose) tocSheetClose.addEventListener('click', closeSheet);
          if (tocSheetOverlay) tocSheetOverlay.addEventListener('click', closeSheet);
        }

        headings.forEach((heading, i) => {
          if (!heading.id) heading.id = 'toc-' + i;
          const isH3 = heading.tagName === 'H3';
          let cls = 'blog-toc-link';
          if (isH3) cls += ' blog-toc-link--h3';
          // Add section separator before h2 (except first)
          if (!isH3 && i > 0) cls += ' blog-toc-link--section';

          const makeLink = (afterClick) => {
            const link = document.createElement('a');
            link.href = '#' + heading.id;
            link.textContent = heading.textContent.trim();
            link.className = cls;
            link.addEventListener('click', (e) => {
              e.preventDefault();
              heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
              if (afterClick) afterClick();
            });
            return link;
          };

          tocNav.appendChild(makeLink());
          if (tocNavMobile) tocNavMobile.appendChild(makeLink(closeSheet));
        });

        // Scroll spy with IntersectionObserver — sync active state in both navs
        const activeLinks = new Set();
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              activeLinks.forEach(l => l.classList.remove('blog-toc-link--active'));
              activeLinks.clear();
              const selector = 'a[href="#' + entry.target.id + '"]';
              const desktopLink = tocNav.querySelector(selector);
              const mobileLink = tocNavMobile && tocNavMobile.querySelector(selector);
              if (desktopLink) {
                desktopLink.classList.add('blog-toc-link--active');
                activeLinks.add(desktopLink);
                desktopLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
              }
              if (mobileLink) {
                mobileLink.classList.add('blog-toc-link--active');
                activeLinks.add(mobileLink);
              }
            }
          });
        }, { root: mainEl, rootMargin: '0px 0px -80% 0px', threshold: 0 });

        headings.forEach(h => observer.observe(h));

        // Category expand/collapse toggles
        document.querySelectorAll('.blog-category-toggle').forEach(btn => {
          btn.addEventListener('click', () => {
            const list = btn.closest('.blog-category-posts');
            if (!list) return;
            const expanded = list.classList.toggle('blog-category--expanded');
            const count = btn.dataset.count;
            const others = btn.dataset.others;
            btn.textContent = expanded ? '↑' : `+${count} ${others}`;
          });
        });
      });
    </script>
    <Analytics />
  </body>
</html>

