---
import LandingLayout from '../layouts/LandingLayout.astro';
import McpServerContent from '../features/mcp-server/McpServerContent.astro';

const locale = (Astro as any).currentLocale ?? 'en';
const pageTitle = locale === 'fr'
  ? 'Framework MCP Production — @casys/mcp-server | Casys AI'
  : 'Production MCP Server Framework — @casys/mcp-server | Casys AI';
const description = locale === 'fr'
  ? 'Framework MCP production-grade avec middleware composable, auth OAuth2, double transport. Le Hono pour MCP.'
  : 'Production-grade MCP server framework with composable middleware, OAuth2 auth, dual transport. The Hono for MCP.';
const jsonLd = [{
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  "name": "@casys/mcp-server",
  "description": "Production MCP server framework with composable middleware, OAuth2 auth, dual transport.",
  "codeRepository": "https://github.com/Casys-AI/mcp-server",
  "programmingLanguage": "TypeScript",
  "runtimePlatform": ["Node.js", "Deno", "Vercel Edge"],
  "license": "https://spdx.org/licenses/MIT",
  "author": { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
  "applicationCategory": "DeveloperApplication",
  "keywords": ["MCP", "Model Context Protocol", "AI agents", "TypeScript", "OAuth2"]
}];
---

<LandingLayout title={pageTitle} description={description} jsonLd={jsonLd}>
  <McpServerContent />
</LandingLayout>
