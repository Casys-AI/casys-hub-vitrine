---
import LandingLayout from '../../layouts/LandingLayout.astro';
import McpProductPage from '../../features/landing-v2/McpProductPage.astro';
import { useTranslations } from '../../i18n';

const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).mcpErpnextPage;
const localePrefix = locale === 'en' ? '' : `/${locale}`;
---

<LandingLayout title="MCP ERPNext | Casys AI" description="A concrete MCP workflow on top of ERPNext. See the demo, understand the workflow, and trace the stack behind it." ogImage="/og/use-case/mcp-erpnext.png">
  <McpProductPage content={content} githubUrl="https://github.com/Casys-AI/mcp-erpnext" localePrefix={localePrefix} />
</LandingLayout>
