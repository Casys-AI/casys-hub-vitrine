---
import LandingLayout from '../../layouts/LandingLayout.astro';
import McpBridgeContent from '../../features/mcp-bridge/McpBridgeContent.astro';

const pageTitle = '@casys/mcp-bridge — MCP Apps Telegram & LINE | Casys';
const description = 'Bridge MCP Apps vers Telegram Mini Apps et LINE LIFF. Transformez vos outils MCP en apps de messagerie. TypeScript, OAuth2, architecture 3 couches avec JSON-RPC 2.0 sur WebSocket.';
const jsonLd = [{
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  "name": "@casys/mcp-bridge",
  "description": "MCP to Telegram Mini Apps bridge. Deploy MCP tools as cross-platform messaging apps.",
  "codeRepository": "https://github.com/Casys-AI/casys-pml/tree/main/lib/mcp-apps-bridge",
  "programmingLanguage": "TypeScript",
  "runtimePlatform": ["Node.js", "Deno"],
  "license": "https://spdx.org/licenses/MIT",
  "author": { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
  "applicationCategory": "DeveloperApplication",
  "keywords": ["MCP", "MCP Apps", "Telegram", "Bridge", "TypeScript"]
}];
---

<LandingLayout title={pageTitle} description={description} jsonLd={jsonLd}>
  <McpBridgeContent />
</LandingLayout>
