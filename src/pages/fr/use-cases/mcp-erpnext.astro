---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import McpProductPage from '../../../features/landing-v2/McpProductPage.astro';
import { useTranslations } from '../../../i18n';

const locale = (Astro as any).currentLocale ?? 'fr';
const content = useTranslations(locale).mcpErpnextPage;
const localePrefix = locale === 'en' ? '' : `/${locale}`;
---

<LandingLayout title="MCP ERPNext | Casys AI" description="Un workflow MCP concret sur ERPNext. Voyez la démo, comprenez le workflow, tracez la stack derrière." ogImage="/og/use-case/mcp-erpnext-fr.png">
  <McpProductPage content={content} githubUrl="https://github.com/Casys-AI/mcp-erpnext" localePrefix={localePrefix} />
</LandingLayout>
