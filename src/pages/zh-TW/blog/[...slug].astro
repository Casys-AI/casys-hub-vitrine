---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import AuthorByline from '../../../components/AuthorByline.astro';

const locale = 'zh-TW';

const labels = {
  backToBlog: '返回部落格',
  updatedOn: '更新於',
  relatedArticles: '相關文章',
  readArticle: '閱讀文章',
  allArticles: '所有文章',
  shareLinkedin: '分享到 LinkedIn',
  copyLink: '複製連結',
  copied: '已複製！',
};

export const prerender = true;

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog', ({ data, id }) => {
    return !data.draft && id.startsWith('zh-TW/');
  });

  return blogPosts.map(entry => ({
    params: { slug: entry.slug.replace(/^zh-tw\//i, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return Astro.redirect('/zh-TW/blog');
}

const { Content } = await entry.render();

// Lookup EN version for OG tags (always show English in social previews)
const bareSlug = entry.slug.replace(/^zh-tw\//i, '');
const enPosts = await getCollection('blog', ({ data, id }) => !data.draft && id.startsWith('en/'));
const enVersion = enPosts.find(p => p.slug.replace('en/', '') === bareSlug);
const ogTitle = enVersion?.data.title;
const ogDescription = enVersion?.data.description;

// Related articles
const allPosts = await getCollection('blog', ({ data, id }) => !data.draft && id.startsWith('zh-TW/'));
const relatedPosts = allPosts
  .filter(post =>
    post.slug !== entry.slug && (
      post.data.category === entry.data.category ||
      post.data.tags.some(tag => entry.data.tags.includes(tag))
    )
  )
  .slice(0, 3);

function getPostSlug(post: typeof allPosts[0]) {
  return post.slug.replace(/^zh-tw\//i, '');
}
---

<BlogLayout title={entry.data.title} locale={locale} description={entry.data.description} slug={entry.slug.replace(/^zh-tw\//i, '')} ogTitle={ogTitle} ogDescription={ogDescription} datePublished={entry.data.date?.toISOString()} dateModified={entry.data.updatedAt?.toISOString()} author={entry.data.author} tags={entry.data.tags} category={entry.data.category}>
  <!-- Back navigation -->
  <nav class="back-nav">
    <a href="/zh-TW/blog" class="back-link">
      <span class="back-arrow">&larr;</span> {labels.backToBlog}
    </a>
  </nav>

  <!-- Article header -->
  <header class="article-header">
    {entry.data.category && (
      <div class="category-wrapper">
        <span class="category-badge">
          {entry.data.category}
        </span>
      </div>
    )}

    <h1 class="article-title">
      {entry.data.title}
    </h1>

    {entry.data.description && (
      <p class="article-description">
        {entry.data.description}
      </p>
    )}

    <!-- Metadata -->
    <div class="article-meta">
      <div class="meta-item">
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('zh-TW', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      </div>

      <span class="meta-separator">&middot;</span>

      <div class="meta-item">
        <AuthorByline author={entry.data.author} locale={locale} />
      </div>

      {entry.data.updatedAt && (
        <>
          <span class="meta-separator">&middot;</span>
          <div class="meta-item">
            <span>
              {labels.updatedOn} {entry.data.updatedAt.toLocaleDateString('zh-TW')}
            </span>
          </div>
        </>
      )}
    </div>

    <!-- Tags -->
    {entry.data.tags.length > 0 && (
      <div class="tags-wrapper">
        {entry.data.tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}
  </header>

  <!-- Article content -->
  <article class="prose">
    <Content />
  </article>

  <!-- Related articles -->
  {relatedPosts.length > 0 && (
    <section class="related-section">
      <h2 class="related-title">{labels.relatedArticles}</h2>

      <div class="related-grid">
        {relatedPosts.map((post) => (
          <article class="related-card">
            <div class="related-card-body">
              <h3 class="related-card-title">
                <a href={`/zh-TW/blog/${getPostSlug(post)}`}>
                  {post.data.title}
                </a>
              </h3>

              <div class="related-card-date">
                {post.data.date.toLocaleDateString('zh-TW')}
              </div>

              {post.data.description && (
                <p class="related-card-desc">
                  {post.data.description}
                </p>
              )}

              <div class="related-card-tags">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="related-tag">{tag}</span>
                ))}
              </div>
            </div>

            <a href={`/zh-TW/blog/${getPostSlug(post)}`} class="related-card-link">
              {labels.readArticle} &rarr;
            </a>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Navigation -->
  <nav class="bottom-nav">
    <div class="bottom-nav-inner">
      <div class="bottom-nav-back">
        <a href="/zh-TW/blog">
          &larr; {labels.allArticles}
        </a>
      </div>

      <div class="bottom-nav-share">
        <button class="share-btn share-btn--linkedin" data-title={entry.data.title} aria-label={labels.shareLinkedin}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          {labels.shareLinkedin}
        </button>
        <button class="share-btn share-btn--copy" aria-label={labels.copyLink} data-copied={labels.copied} data-label={labels.copyLink}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          {labels.copyLink}
        </button>
      </div>
    </div>
  </nav>
</BlogLayout>

<style>
  .back-nav { margin-bottom: 2rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; color: var(--md-sys-color-on-surface-variant, #5f6368); text-decoration: none; transition: color 0.2s ease; letter-spacing: 0.01em; }
  .back-link:hover { color: var(--md-sys-color-primary, #6750a4); }
  .back-arrow { font-size: 1rem; transition: transform 0.2s ease; }
  .back-link:hover .back-arrow { transform: translateX(-2px); }
  .article-header { margin-bottom: 3rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--md-sys-color-outline-variant, #c4c7c5); }
  .category-wrapper { margin-bottom: 1.25rem; }
  .category-badge { display: inline-flex; align-items: center; padding: 0.25rem 0.875rem; border-radius: 100px; font-family: 'Inter', sans-serif; font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; background-color: var(--md-sys-color-primary-container, #eaddff); color: var(--md-sys-color-on-primary-container, #21005d); }
  .article-title { font-family: 'Fraunces', Georgia, serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; line-height: 1.15; color: var(--md-sys-color-on-surface, #1c1b1f); margin: 0 0 1.25rem 0; letter-spacing: -0.02em; font-optical-sizing: auto; }
  .article-description { font-family: 'Inter', sans-serif; font-size: 1.25rem; line-height: 1.6; color: var(--md-sys-color-on-surface-variant, #49454f); margin: 0 0 1.75rem 0; max-width: 42em; }
  .article-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; font-family: 'Inter', sans-serif; font-size: 0.875rem; color: var(--md-sys-color-on-surface-variant, #5f6368); }
  .meta-item { display: flex; align-items: center; }
  .meta-separator { color: var(--md-sys-color-outline, #79747e); user-select: none; }
  .tags-wrapper { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.25rem; }
  .tag { display: inline-flex; align-items: center; padding: 0.1875rem 0.625rem; border-radius: 100px; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 500; background-color: var(--md-sys-color-surface-container, #f3edf7); color: var(--md-sys-color-on-surface-variant, #49454f); letter-spacing: 0.02em; }
  .prose { font-family: 'Inter', sans-serif; font-size: 1.125rem; line-height: 1.8; color: var(--md-sys-color-on-surface, #1c1b1f); max-width: 72ch; margin-bottom: 4rem; overflow-x: hidden; }
  .prose table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .related-section { border-top: 1px solid var(--md-sys-color-outline-variant, #c4c7c5); padding-top: 3rem; }
  .related-title { font-family: 'Fraunces', Georgia, serif; font-size: 1.75rem; font-weight: 600; color: var(--md-sys-color-on-surface, #1c1b1f); margin: 0 0 2rem 0; letter-spacing: -0.01em; }
  .related-grid { display: grid; gap: 1.5rem; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .related-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .related-grid { grid-template-columns: repeat(3, 1fr); } }
  .related-card { display: flex; flex-direction: column; justify-content: space-between; background-color: var(--md-sys-color-surface-container-low, #f7f2fa); border-radius: 12px; border: 1px solid var(--md-sys-color-outline-variant, #c4c7c5); padding: 1.5rem; transition: box-shadow 0.2s ease, transform 0.2s ease; }
  .related-card:hover { box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08); transform: translateY(-2px); }
  .related-card-body { margin-bottom: 1rem; }
  .related-card-title { font-family: 'Fraunces', Georgia, serif; font-size: 1.125rem; font-weight: 600; line-height: 1.35; margin: 0 0 0.5rem 0; color: var(--md-sys-color-on-surface, #1c1b1f); }
  .related-card-title a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  .related-card-title a:hover { color: var(--md-sys-color-primary, #6750a4); }
  .related-card-date { font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: var(--md-sys-color-on-surface-variant, #5f6368); margin-bottom: 0.625rem; }
  .related-card-desc { font-family: 'Inter', sans-serif; font-size: 0.875rem; line-height: 1.55; color: var(--md-sys-color-on-surface-variant, #49454f); margin: 0 0 0.75rem 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .related-card-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .related-tag { display: inline-flex; align-items: center; padding: 0.125rem 0.5rem; border-radius: 6px; font-family: 'Inter', sans-serif; font-size: 0.6875rem; font-weight: 500; background-color: var(--md-sys-color-surface-container, #f3edf7); color: var(--md-sys-color-on-surface-variant, #49454f); }
  .related-card-link { font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 600; color: var(--md-sys-color-primary, #6750a4); text-decoration: none; transition: color 0.2s ease, gap 0.2s ease; }
  .related-card-link:hover { color: var(--md-sys-color-primary, #4a3a8a); text-decoration: underline; text-underline-offset: 3px; }
  .bottom-nav { border-top: 1px solid var(--md-sys-color-outline-variant, #c4c7c5); padding-top: 2.5rem; margin-top: 3rem; }
  .bottom-nav-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  .bottom-nav-back a { font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; color: var(--md-sys-color-on-surface-variant, #5f6368); text-decoration: none; transition: color 0.2s ease; }
  .bottom-nav-back a:hover { color: var(--md-sys-color-primary, #6750a4); }
  .bottom-nav-share { display: flex; gap: 0.5rem; align-items: center; }
  .share-btn { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.4rem 0.75rem; font-family: 'Inter', sans-serif; font-size: 0.8125rem; font-weight: 500; color: var(--md-sys-color-on-surface-variant, #79747e); background: none; border: 1px solid var(--md-sys-color-outline-variant, #e7e5e4); border-radius: 8px; cursor: pointer; transition: color 0.15s, border-color 0.15s, background-color 0.15s; }
  .share-btn:hover { color: var(--md-sys-color-primary, #6750a4); border-color: var(--md-sys-color-primary, #6750a4); background-color: var(--md-sys-color-surface-variant, #f5f5f4); }
  .share-btn svg { flex-shrink: 0; }
</style>

<style is:global>
  html[data-theme="dark"] .back-link { color: #d5c3b5; }
  html[data-theme="dark"] .back-link:hover { color: #FFB86F; }
  html[data-theme="dark"] .article-header { border-bottom-color: rgba(255, 184, 111, 0.1); }
  html[data-theme="dark"] .category-badge { background-color: rgba(255, 184, 111, 0.12); color: #FFB86F; }
  html[data-theme="dark"] .article-title { color: #f5f0ea; }
  html[data-theme="dark"] .article-description { color: #d5c3b5; }
  html[data-theme="dark"] .article-meta { color: #d5c3b5; }
  html[data-theme="dark"] .meta-separator { color: rgba(255, 184, 111, 0.3); }
  html[data-theme="dark"] .tag { background-color: rgba(255, 184, 111, 0.08); color: #d5c3b5; }
  html[data-theme="dark"] .prose { color: #f5f0ea; }
  html[data-theme="dark"] .related-section { border-top-color: rgba(255, 184, 111, 0.1); }
  html[data-theme="dark"] .related-title { color: #f5f0ea; }
  html[data-theme="dark"] .related-card { background-color: #1a1815; border-color: rgba(255, 184, 111, 0.1); }
  html[data-theme="dark"] .related-card:hover { box-shadow: 0 4px 20px rgba(255, 184, 111, 0.06); border-color: rgba(255, 184, 111, 0.2); }
  html[data-theme="dark"] .related-card-title { color: #f5f0ea; }
  html[data-theme="dark"] .related-card-title a:hover { color: #FFB86F; }
  html[data-theme="dark"] .related-card-date { color: #d5c3b5; }
  html[data-theme="dark"] .related-card-desc { color: #d5c3b5; }
  html[data-theme="dark"] .related-tag { background-color: rgba(255, 184, 111, 0.08); color: #d5c3b5; }
  html[data-theme="dark"] .related-card-link { color: #FFB86F; }
  html[data-theme="dark"] .related-card-link:hover { color: #ffc98f; }
  html[data-theme="dark"] .bottom-nav { border-top-color: rgba(255, 184, 111, 0.1); }
  html[data-theme="dark"] .bottom-nav-back a { color: #d5c3b5; }
  html[data-theme="dark"] .bottom-nav-back a:hover { color: #FFB86F; }
  html[data-theme="dark"] .share-btn { color: #a89b8c; border-color: rgba(255, 184, 111, 0.15); }
  html[data-theme="dark"] .share-btn:hover { color: #FFB86F; border-color: #FFB86F; background-color: rgba(255, 184, 111, 0.06); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const linkedinBtn = document.querySelector('.share-btn--linkedin');
    const copyBtn = document.querySelector('.share-btn--copy');

    if (linkedinBtn) {
      linkedinBtn.addEventListener('click', () => {
        const url = encodeURIComponent(window.location.href);
        const title = encodeURIComponent(linkedinBtn.dataset.title || '');
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${url}`, '_blank', 'width=600,height=500');
      });
    }

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(window.location.href);
        const label = copyBtn.dataset.label;
        const copied = copyBtn.dataset.copied;
        const svg = copyBtn.querySelector('svg');
        copyBtn.textContent = copied;
        if (svg) copyBtn.prepend(svg);
        setTimeout(() => {
          copyBtn.textContent = label;
          if (svg) copyBtn.prepend(svg);
        }, 2000);
      });
    }
  });
</script>
