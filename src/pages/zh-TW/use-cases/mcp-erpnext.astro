---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import McpProductPage from '../../../features/landing-v2/McpProductPage.astro';
import { useTranslations } from '../../../i18n';

const locale = (Astro as any).currentLocale ?? 'zh-TW';
const content = useTranslations(locale).mcpErpnextPage;
const localePrefix = locale === 'en' ? '' : `/${locale}`;
---

<LandingLayout title="MCP ERPNext | Casys AI" description="基於 ERPNext 的具體 MCP 工作流。查看示範，了解工作流，追蹤背後的技術棧。">
  <McpProductPage content={content} githubUrl="https://github.com/Casys-AI/mcp-erpnext" localePrefix={localePrefix} />
</LandingLayout>
