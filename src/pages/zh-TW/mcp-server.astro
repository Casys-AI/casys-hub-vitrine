---
import LandingLayout from '../../layouts/LandingLayout.astro';
import McpServerContent from '../../features/mcp-server/McpServerContent.astro';

const pageTitle = '生產級 MCP 伺服器框架 — @casys/mcp-server | Casys';
const description = 'MCP 伺服器框架，具備可組合中介軟體、OAuth2 驗證、速率限制、雙傳輸模式（STDIO + HTTP/SSE），已在生產環境驗證。TypeScript，支援 Deno 與 Node.js。發佈於 JSR，MIT 開源授權，附帶完整文件。MCP 界的 Hono。';
const jsonLd = [{
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  "name": "@casys/mcp-server",
  "description": "Production MCP server framework with composable middleware, OAuth2 auth, dual transport.",
  "codeRepository": "https://github.com/Casys-AI/mcp-server",
  "programmingLanguage": "TypeScript",
  "runtimePlatform": ["Node.js", "Deno", "Vercel Edge"],
  "license": "https://spdx.org/licenses/MIT",
  "author": { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
  "applicationCategory": "DeveloperApplication",
  "keywords": ["MCP", "Model Context Protocol", "AI agents", "TypeScript", "OAuth2"]
}];
---

<LandingLayout title={pageTitle} description={description} jsonLd={jsonLd}>
  <McpServerContent />
</LandingLayout>
