---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import McpProductPage from '../../../features/landing-v2/McpProductPage.astro';
import { useTranslations } from '../../../i18n';

const locale = (Astro as any).currentLocale ?? 'zh';
const content = useTranslations(locale).mcpErpnextPage;
const localePrefix = locale === 'en' ? '' : `/${locale}`;
const jsonLd = [{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "MCP ERPNext integration",
  "description": "Production MCP server for ERPNext with 97 tools — procurement, inventory, accounting, HR. Open source, OAuth2-secured, deployable today.",
  "provider": { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
  "serviceType": "AI integration",
  "areaServed": ["FR", "US", "TW", "JP", "Worldwide"],
  "category": "AI Agents / ERP Integration",
  "url": "https://github.com/Casys-AI/mcp-erpnext"
}];
---

<LandingLayout title="MCP ERPNext | Casys" description="基于 ERPNext 的具体 MCP 工作流。查看演示，了解工作流，追踪背后的技术栈。" jsonLd={jsonLd}>
  <McpProductPage content={content} githubUrl="https://github.com/Casys-AI/mcp-erpnext" localePrefix={localePrefix} />
</LandingLayout>
