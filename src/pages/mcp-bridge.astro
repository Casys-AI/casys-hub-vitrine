---
import LandingLayout from '../layouts/LandingLayout.astro';
import McpBridgeContent from '../features/mcp-bridge/McpBridgeContent.astro';

const locale = (Astro as any).currentLocale ?? 'en';
const pageTitle = locale === 'fr'
  ? 'Bridge MCP Apps vers Telegram & LINE — @casys/mcp-bridge | Casys AI'
  : 'MCP Apps Bridge for Telegram & LINE — @casys/mcp-bridge | Casys AI';
const description = locale === 'fr'
  ? 'Bridge MCP Apps vers Telegram Mini Apps et LINE LIFF. Transformez vos outils MCP en apps de messagerie.'
  : 'Bridge MCP Apps to Telegram Mini Apps and LINE LIFF. Turn your MCP tools into messaging apps.';
---

<LandingLayout title={pageTitle} description={description}>
  <McpBridgeContent />
</LandingLayout>
