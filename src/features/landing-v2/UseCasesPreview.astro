---
import { useTranslations } from '../../i18n';
import { useCases } from '../../content/use-cases';

const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).useCases;
const featuredDemo = useTranslations(locale).featuredDemo;
const localePath = locale === 'en' ? '' : `/${locale}`;

const readCaseLabel =
  locale === 'fr'
    ? 'Lire le cas'
    : locale === 'zh'
      ? '阅读案例'
      : locale === 'zh-TW'
        ? '閱讀案例'
        : 'Read case study';

const allCasesLabel =
  locale === 'fr'
    ? 'Tous les cas'
    : locale === 'zh'
      ? '所有案例'
      : locale === 'zh-TW'
        ? '所有案例'
        : 'All case studies';
---

<section id="use-cases-preview">
  <div class="container">
    <div class="section-header">
      <h2>{t.heroTitle}</h2>
      <p class="section-subtitle">{t.heroSubtitle}</p>
    </div>

    <div id="featured-demo" class="featured-case">
      <div class="featured-video-card">
        <video controls playsinline preload="metadata"><source src={featuredDemo.video.src} type="video/mp4" /></video>
        <p class="video-caption">{featuredDemo.video.caption}</p>
      </div>

      <div class="featured-copy">
        <span class="eyebrow">{featuredDemo.eyebrow}</span>
        <h3 class="featured-title">{featuredDemo.name}</h3>
        <p class="featured-tagline">{featuredDemo.tagline}</p>
        <p class="featured-description">{featuredDemo.description}</p>

        <ul class="featured-bullets">
          {featuredDemo.bullets.map((bullet) => (
            <li class="bullet-item">
              <span class="material-symbols-rounded">check_circle</span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>

        <p class="featured-note">{featuredDemo.note}</p>
      </div>
    </div>

    <div class="cases-grid">
      {useCases.map((uc) => (
        <article class="case-card">
          <a href={`${localePath}/use-cases/${uc.id}`} class="case-card-link">
            <div class="case-media">
              <img
                src={`/og/use-case/${uc.id}.png`}
                alt={uc.title[locale] || uc.title.en}
                loading="lazy"
                class="case-image og-thumbnail"
              />
            </div>

            <div class="case-copy">
              <span class="case-tag">
                <span class="material-symbols-rounded tag-icon">{uc.icon}</span>
                {uc.tag}
              </span>

              <h3 class="case-title">{uc.title[locale] || uc.title.en}</h3>
              <p class="case-excerpt">{uc.punchline[locale] || uc.punchline.en}</p>

              <span class="read-link">
                {readCaseLabel}
                <span aria-hidden="true">&rarr;</span>
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="view-all-wrapper">
      <a href={`${localePath}/use-cases`} class="view-all-link">
        {allCasesLabel}
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  section {
    padding: 56px 0;
    background: var(--md-sys-color-surface-container);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-header {
    text-align: left;
    margin-bottom: 40px;
    max-width: 620px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  .featured-case {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 32px;
    margin-bottom: 40px;
    padding: 18px;
    background: var(--md-sys-color-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 24px;
    transition: box-shadow 300ms ease-out, border-color 300ms ease-out;
  }

  .featured-case:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
    border-color: var(--md-sys-color-primary);
  }

  .featured-video-card {
    overflow: hidden;
  }

  video {
    width: 100%;
    display: block;
    border-radius: 14px;
    background: #000;
  }

  .video-caption {
    margin: 14px 4px 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--md-sys-color-on-surface-variant);
  }

  .featured-copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 12px;
    border-left: 4px solid var(--md-sys-color-primary);
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--md-sys-color-primary);
  }

  .featured-title,
  .case-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .featured-title {
    font-size: 1.8rem;
    line-height: 1.2;
  }

  .case-title {
    font-size: 1.45rem;
    line-height: 1.3;
  }

  .featured-tagline {
    margin: -6px 0 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.08rem;
    font-style: italic;
    color: var(--md-sys-color-primary);
  }

  .featured-description,
  .featured-note,
  .case-excerpt {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--md-sys-color-on-surface-variant);
  }

  .featured-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  .bullet-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    color: var(--md-sys-color-on-surface);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .bullet-item .material-symbols-rounded {
    font-size: 18px;
    color: var(--md-sys-color-primary);
    margin-top: 2px;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .case-card {
    background: var(--md-sys-color-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 240ms ease-out, box-shadow 240ms ease-out, border-color 240ms ease-out;
  }

  .case-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .case-card-link,
  .case-card-link * {
    text-decoration: none;
  }

  .case-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    border-color: var(--md-sys-color-primary);
  }

  .case-card-link:focus-visible {
    outline: 3px solid var(--md-sys-color-primary);
    outline-offset: 4px;
    border-radius: 16px;
  }

  .case-media {
    min-height: 220px;
    background: var(--md-sys-color-surface-container-lowest);
    overflow: hidden;
  }

  .case-diagram {
    padding: 12px;
  }

  .case-diagram :global(.excalidraw-figure) {
    margin: 0;
  }

  .case-diagram :global(.excalidraw-wrapper) {
    max-width: 100%;
    border-radius: 8px;
  }

  .case-diagram :global(.excalidraw-caption) {
    display: none;
  }

  .case-image {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: contain;
    padding: 20px 22px;
  }

  .case-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 14px;
    padding: 22px;
  }

  .case-tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    align-self: flex-start;
    padding: 5px 10px;
    border-radius: 6px;
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-primary);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .tag-icon {
    font-size: 13px;
  }

  .read-link {
    margin-top: auto;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--md-sys-color-primary);
    font-size: 0.9rem;
    font-weight: 600;
    transition: gap 200ms ease-out;
  }

  .case-card:hover .read-link {
    gap: 10px;
  }

  .view-all-wrapper {
    margin-top: 40px;
    text-align: center;
  }

  .view-all-link {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-on-primary);
    background: var(--md-sys-color-primary);
    border: none;
    border-radius: 12px;
    transition: background 200ms ease-out, transform 200ms ease-out, box-shadow 200ms ease-out;
  }

  .view-all-link:hover {
    background: var(--md-sys-color-primary);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(128, 0, 128, 0.2);
  }

  .view-all-link:focus-visible {
    outline: 3px solid var(--md-sys-color-primary);
    outline-offset: 4px;
  }

  @media (max-width: 900px) {
    .featured-case,
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 32px 0;
    }

    .container {
      padding: 0 16px;
    }

    h2 {
      font-size: 2rem;
    }

    .featured-case {
      gap: 24px;
      padding: 16px;
    }

    .featured-copy {
      padding: 4px 0 0;
      border-left: 0;
      border-top: 4px solid var(--md-sys-color-primary);
      padding-top: 16px;
    }

    .featured-title {
      font-size: 1.5rem;
    }

    .case-title {
      font-size: 1.25rem;
    }

    .case-copy {
      padding: 18px;
    }

    .view-all-wrapper {
      margin-top: 32px;
    }

    .view-all-link {
      width: 100%;
    }
  }
</style>

<style is:global>
  html[data-theme="dark"] #use-cases-preview {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #use-cases-preview h2,
  html[data-theme="dark"] #use-cases-preview .featured-title,
  html[data-theme="dark"] #use-cases-preview .case-title {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #use-cases-preview .section-subtitle,
  html[data-theme="dark"] #use-cases-preview .video-caption,
  html[data-theme="dark"] #use-cases-preview .featured-description,
  html[data-theme="dark"] #use-cases-preview .featured-note,
  html[data-theme="dark"] #use-cases-preview .case-excerpt {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #use-cases-preview .featured-case,
  html[data-theme="dark"] #use-cases-preview .case-card {
    background: var(--casys-warm-surface);
    border-color: var(--casys-warm-border-accent);
  }

  html[data-theme="dark"] #use-cases-preview .featured-copy {
    border-left-color: var(--casys-warm-accent);
  }

  @media (max-width: 768px) {
    html[data-theme="dark"] #use-cases-preview .featured-copy {
      border-top-color: var(--casys-warm-accent);
    }
  }

  html[data-theme="dark"] #use-cases-preview .eyebrow,
  html[data-theme="dark"] #use-cases-preview .featured-tagline,
  html[data-theme="dark"] #use-cases-preview .read-link,
  html[data-theme="dark"] #use-cases-preview .view-all-link {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #use-cases-preview .bullet-item {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #use-cases-preview .bullet-item .material-symbols-rounded {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #use-cases-preview .case-media {
    background: #08080a;
  }

  html[data-theme="dark"] #use-cases-preview .og-thumbnail {
    filter: invert(1) hue-rotate(180deg);
    opacity: 0.9;
  }

  html[data-theme="dark"] #use-cases-preview .case-tag {
    color: var(--casys-warm-accent);
    background: var(--casys-warm-border-accent);
  }

  html[data-theme="dark"] #use-cases-preview .view-all-link {
    border-color: var(--casys-warm-border-accent);
  }

  html[data-theme="dark"] #use-cases-preview .view-all-link:hover {
    border-color: var(--casys-warm-accent);
    background: var(--casys-warm-border-accent);
  }
 </style>
