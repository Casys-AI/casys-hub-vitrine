---
/**
 * Interlude — Material Expressive "emphasis container"
 *
 * Full-width visual break between dense card sections.
 * Display typography + key stats + generous whitespace.
 * NOT a content section — it's a rhythm marker.
 */
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).interlude;
---

<section id="interlude" aria-label={content.ariaLabel}>
  <div class="container">
    <blockquote class="pull-quote">
      <p>{content.quote}</p>
    </blockquote>

    <div class="stats-ribbon">
      {content.stats.map((stat: { value: string; label: string }) => (
        <div class="stat">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 0;
    background: var(--md-sys-color-surface-container-low);
    border-top: 1px solid var(--md-sys-color-outline-variant);
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
  }

  /* Pull quote — display typography, centered */
  .pull-quote {
    margin: 0;
    padding: 0;
    text-align: center;
    max-width: 720px;
  }

  .pull-quote p {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* Stats ribbon — horizontal, generous spacing */
  .stats-ribbon {
    display: flex;
    justify-content: center;
    gap: 64px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    min-width: 100px;
  }

  .stat-value {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-primary);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
  }

  @media (max-width: 768px) {
    section {
      padding: 56px 0;
    }

    .container {
      gap: 40px;
    }

    .stats-ribbon {
      gap: 32px;
    }

    .stat {
      min-width: 80px;
    }
  }

  @media (max-width: 480px) {
    .stats-ribbon {
      gap: 24px;
    }
  }
</style>

<style is:global>
  /* ===== DARK MODE ===== */
  html[data-theme="dark"] #interlude {
    background: var(--casys-warm-surface);
    border-top-color: rgba(255, 184, 111, 0.1);
    border-bottom-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #interlude .pull-quote p {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #interlude .stat-value {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #interlude .stat-label {
    color: var(--casys-warm-text-muted);
  }
</style>
