---
import { useTranslations } from '../../i18n';
import { isExternalUrl } from '../../lib/url-utils';

const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).whyCasys;
const leadCard = content.differentiation[0];
const sideCard = content.differentiation[1];
const lowerCards = content.differentiation.slice(2);
---

<section id="why-casys">
  <div class="container">
    <header class="section-intro">
      <p class="section-kicker">{content.subtitle}</p>
      <h2>{content.title}</h2>
    </header>

    <div class="bento-grid">
      {leadCard && (
        <article class="feature-card feature-card-lead">
          <div class="feature-shell">
            <span class="material-symbols-rounded card-icon" aria-hidden="true">{leadCard.icon}</span>

            <div class="card-copy">
              <h3>{leadCard.title}</h3>
              <p class="card-description">{leadCard.description}</p>
            </div>

            <div class="trajectory">
              {leadCard.highlights.map((highlight) => (
                <div class="trajectory-item">
                  <span class="trajectory-dot" aria-hidden="true"></span>
                  <span>{highlight}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="lead-texture" aria-hidden="true"></div>
        </article>
      )}

      {sideCard && (
        <article class="feature-card feature-card-side">
          <div class="card-copy">
            <span class="material-symbols-rounded card-icon" aria-hidden="true">{sideCard.icon}</span>
            <h3>{sideCard.title}</h3>
            <p class="card-description">{sideCard.description}</p>
          </div>

          <div class="card-footer-note">{sideCard.highlights[0]}</div>
        </article>
      )}

      {lowerCards.map((item, index) => (
        <article class={`feature-card feature-card-small feature-card-small-${index + 1}`}>
          <div class="card-copy">
            <span class="material-symbols-rounded card-icon" aria-hidden="true">{item.icon}</span>
            <h3>{item.title}</h3>
            <p class="card-description">{item.description}</p>
          </div>

          <ul class="mini-highlights">
            {item.highlights.map((highlight) => (
              <li>
                <span class="material-symbols-rounded" aria-hidden="true">subdirectory_arrow_right</span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    {content.bottomLine && (
      <div class="signature-band">
        <span class="material-symbols-rounded quote-mark" aria-hidden="true">format_quote</span>
        <blockquote>{content.bottomLine.text}</blockquote>

        <div class="signature-actions">
          <a href={content.bottomLine.cta.primary.url} class="cta-primary">
            <span class="material-symbols-rounded" aria-hidden="true">{content.bottomLine.cta.primary.icon}</span>
            <span>{content.bottomLine.cta.primary.text}</span>
          </a>
          <a
            href={content.bottomLine.cta.secondary.url}
            class="cta-secondary"
            target={isExternalUrl(content.bottomLine.cta.secondary.url) ? '_blank' : undefined}
            rel={isExternalUrl(content.bottomLine.cta.secondary.url) ? 'noopener noreferrer' : undefined}
          >
            <span class="material-symbols-rounded" aria-hidden="true">{content.bottomLine.cta.secondary.icon}</span>
            <span>{content.bottomLine.cta.secondary.text}</span>
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  #why-casys {
    position: relative;
    padding: 88px 0 96px;
    background:
      radial-gradient(circle at top right, rgba(157, 132, 183, 0.06), transparent 28%),
      radial-gradient(circle at top left, rgba(255, 184, 111, 0.08), transparent 35%),
      var(--md-sys-color-surface-container-low);
    overflow: hidden;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  .section-intro {
    max-width: 760px;
    margin-bottom: 40px;
  }

  .section-kicker {
    margin: 0 0 14px;
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
  }

  h2 {
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--md-sys-color-on-surface);
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }

  .feature-card {
    position: relative;
    background: var(--md-sys-color-surface-container);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 28px;
    overflow: hidden;
    min-height: 320px;
    transition: transform 200ms ease, border-color 200ms ease, background 200ms ease, box-shadow 200ms ease;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.12);
  }

  .feature-card-lead {
    grid-column: span 8;
    min-height: 520px;
    background:
      linear-gradient(180deg, rgba(255, 184, 111, 0.05), transparent 55%),
      var(--md-sys-color-surface-container-low);
  }

  .feature-card-side {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 520px;
  }

  .feature-card-small {
    grid-column: span 4;
    min-height: 360px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .feature-shell,
  .feature-card-side,
  .feature-card-small {
    padding: clamp(28px, 3vw, 40px);
  }

  .feature-shell {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100%;
    gap: 28px;
  }

  .card-copy {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 720px;
    position: relative;
    z-index: 1;
  }

  .card-icon {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--md-sys-color-primary);
    background: rgba(255, 184, 111, 0.08);
    font-size: 22px;
  }

  h3 {
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.6rem, 2.4vw, 2.8rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--md-sys-color-on-surface);
  }

  .feature-card-small h3,
  .feature-card-side h3 {
    font-size: clamp(1.35rem, 1.8vw, 2rem);
  }

  .card-description {
    margin: 0;
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--md-sys-color-on-surface-variant);
  }

  .trajectory {
    display: grid;
    gap: 14px;
    max-width: 680px;
    padding-top: 8px;
    border-top: 1px solid rgba(255, 184, 111, 0.14);
  }

  .trajectory-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--md-sys-color-on-surface);
  }

  .trajectory-dot {
    width: 8px;
    height: 8px;
    margin-top: 0.55rem;
    border-radius: 999px;
    flex-shrink: 0;
    background: var(--md-sys-color-primary);
    box-shadow: 0 0 0 5px rgba(255, 184, 111, 0.08);
  }

  .lead-texture {
    position: absolute;
    inset: auto -6% -14% auto;
    width: 48%;
    height: 78%;
    border-radius: 999px;
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 184, 111, 0.2), transparent 28%),
      radial-gradient(circle at 65% 35%, rgba(157, 132, 183, 0.16), transparent 26%),
      linear-gradient(135deg, rgba(255, 184, 111, 0.05), rgba(157, 132, 183, 0.03));
    filter: blur(10px);
    opacity: 0.9;
    pointer-events: none;
  }

  .lead-texture::before,
  .lead-texture::after {
    content: '';
    position: absolute;
    inset: 10%;
    border-radius: 999px;
    border: 1px solid rgba(245, 240, 234, 0.07);
  }

  .lead-texture::after {
    inset: 24%;
    border-color: rgba(255, 184, 111, 0.08);
  }

  .card-footer-note {
    position: relative;
    z-index: 1;
    padding-top: 18px;
    border-top: 1px solid var(--md-sys-color-outline-variant);
    font-family: 'Manrope', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
  }

  .mini-highlights {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: grid;
    gap: 12px;
    position: relative;
    z-index: 1;
  }

  .mini-highlights li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--md-sys-color-on-surface-variant);
  }

  .mini-highlights .material-symbols-rounded {
    margin-top: 1px;
    flex-shrink: 0;
    font-size: 17px;
    color: var(--md-sys-color-primary);
  }

  .signature-band {
    margin-top: 28px;
    padding: clamp(32px, 4vw, 56px);
    border-radius: 28px;
    background: var(--md-sys-color-surface-container-lowest);
    border: 1px solid var(--md-sys-color-outline-variant);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .quote-mark {
    font-size: 3rem;
    color: var(--md-sys-color-primary);
    opacity: 0.32;
  }

  blockquote {
    margin: 0;
    max-width: 900px;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2.8rem);
    line-height: 1.2;
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--md-sys-color-on-surface);
  }

  .signature-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    font-family: 'Manrope', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .cta-primary {
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
  }

  .cta-secondary {
    color: var(--md-sys-color-on-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    background: transparent;
  }

  .cta-primary:hover,
  .cta-secondary:hover {
    transform: translateY(-1px);
  }

  @media (max-width: 960px) {
    .feature-card-lead,
    .feature-card-side,
    .feature-card-small {
      grid-column: 1 / -1;
      min-height: auto;
    }

    .lead-texture {
      width: 46%;
      height: 42%;
      inset: auto -4% -6% auto;
    }
  }

  @media (max-width: 640px) {
    #why-casys {
      padding: 72px 0 80px;
    }

    .bento-grid {
      gap: 18px;
    }

    .feature-shell,
    .feature-card-side,
    .feature-card-small,
    .signature-band {
      padding: 24px;
    }

    .section-kicker {
      font-size: 0.68rem;
      letter-spacing: 0.22em;
    }

    .card-description,
    .mini-highlights li,
    .trajectory-item {
      font-size: 0.92rem;
    }

    .signature-actions {
      width: 100%;
      flex-direction: column;
    }

    .cta-primary,
    .cta-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<style is:global>
  html[data-theme='dark'] #why-casys {
    background:
      radial-gradient(circle at top right, rgba(157, 132, 183, 0.08), transparent 28%),
      radial-gradient(circle at top left, rgba(255, 184, 111, 0.08), transparent 35%),
      var(--casys-warm-background);
  }

  html[data-theme='dark'] #why-casys .feature-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme='dark'] #why-casys .feature-card-lead {
    background:
      linear-gradient(180deg, rgba(255, 184, 111, 0.06), transparent 55%),
      linear-gradient(135deg, rgba(157, 132, 183, 0.05), transparent 42%),
      var(--casys-warm-surface);
  }

  html[data-theme='dark'] #why-casys h2,
  html[data-theme='dark'] #why-casys h3,
  html[data-theme='dark'] #why-casys blockquote,
  html[data-theme='dark'] #why-casys .trajectory-item {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme='dark'] #why-casys .section-kicker,
  html[data-theme='dark'] #why-casys .card-icon,
  html[data-theme='dark'] #why-casys .mini-highlights .material-symbols-rounded,
  html[data-theme='dark'] #why-casys .card-footer-note,
  html[data-theme='dark'] #why-casys .quote-mark {
    color: var(--casys-warm-accent);
  }

  html[data-theme='dark'] #why-casys .card-icon {
    background: rgba(255, 184, 111, 0.08);
  }

  html[data-theme='dark'] #why-casys .card-description,
  html[data-theme='dark'] #why-casys .mini-highlights li,
  html[data-theme='dark'] #why-casys .authority-copy,
  html[data-theme='dark'] #why-casys .signature-band .cta-secondary,
  html[data-theme='dark'] #why-casys .trajectory-item span:last-child {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme='dark'] #why-casys .trajectory {
    border-top-color: rgba(255, 184, 111, 0.14);
  }

  html[data-theme='dark'] #why-casys .trajectory-dot {
    background: var(--casys-warm-accent);
    box-shadow: 0 0 0 5px rgba(255, 184, 111, 0.08);
  }

  html[data-theme='dark'] #why-casys .card-footer-note,
  html[data-theme='dark'] #why-casys .signature-band {
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme='dark'] #why-casys .signature-band {
    background: #100f0d;
  }

  html[data-theme='dark'] #why-casys .cta-primary {
    background: var(--casys-warm-accent);
    color: var(--casys-warm-background);
  }

  html[data-theme='dark'] #why-casys .cta-secondary {
    border-color: rgba(255, 184, 111, 0.16);
    color: var(--casys-warm-text-primary);
  }

  html[data-theme='dark'] #why-casys .feature-card:hover,
  html[data-theme='dark'] #why-casys .cta-secondary:hover {
    border-color: var(--casys-warm-accent);
    background: rgba(255, 184, 111, 0.04);
  }
</style>
