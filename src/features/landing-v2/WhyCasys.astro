---
import { useTranslations } from '../../i18n';
import { isExternalUrl } from '../../lib/url-utils';

const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).whyCasys;
const localePrefix = locale === 'en' ? '' : `/${locale}`;

const founderQuote = locale === 'fr'
  ? "Des chatbots mIRC aux agents MCP. Le problème n'a pas changé : contexte en entrée, action en sortie."
  : locale === 'zh'
  ? "从 mIRC 聊天机器人到 MCP 智能体。问题没变过：输入是上下文，输出是行动。"
  : locale === 'zh-TW'
  ? "從 mIRC 聊天機器人到 MCP 智能體。問題沒變過：輸入是上下文，輸出是行動。"
  : "From mIRC chatbots to MCP agents. The problem hasn't changed: context in, action out.";

const founderRole = locale === 'fr' ? 'Fondateur, Casys'
  : locale === 'zh' ? 'Casys 创办人'
  : locale === 'zh-TW' ? 'Casys 創辦人'
  : 'Founder, Casys';

const aboutLinkLabel = locale === 'fr' ? 'Notre histoire'
  : locale === 'zh' ? '我们的故事'
  : locale === 'zh-TW' ? '我們的故事'
  : 'Our story';

const aboutHref = `${localePrefix}/about`;

const hrefById: Record<string, string> = {
  continuity: aboutHref,
  opensource: content.viewReposUrl,
  practical: `${localePrefix}/use-cases`,
  accessible: content.contactCta.url,
};
---

<section id="why-casys" class="reveal">
  <div class="container">
    <header class="section-header">
      <span class="section-kicker">{content.subtitle}</span>
      <h2>{content.title}</h2>
    </header>

    <div class="manifesto">
      {content.differentiation.map((item) => {
        const href = hrefById[item.id] ?? '#';
        const external = isExternalUrl(href);
        return (
          <a
            href={href}
            class="statement-row"
            aria-label={item.title}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
          >
            <span class="statement-label">— {item.label}</span>
            <h3 class="statement-title">{item.title}</h3>
            <p class="statement-desc">{item.description}</p>
          </a>
        );
      })}
    </div>

    <aside class="founder-band">
      <img
        class="founder-photo"
        src="/images/founder-erwan.webp"
        alt="Erwan Lee Pesle"
        width="112"
        height="112"
        loading="lazy"
      />
      <div class="founder-body">
        <blockquote class="founder-quote">{founderQuote}</blockquote>
        <footer class="founder-attribution">
          <cite>Erwan Lee Pesle</cite>
          <span class="founder-role">{founderRole}</span>
        </footer>
      </div>
      <a href={aboutHref} class="founder-link">
        <span>{aboutLinkLabel}</span>
        <span class="material-symbols-rounded" aria-hidden="true">arrow_outward</span>
      </a>
    </aside>
  </div>
</section>

<style>
  /* ------------------------------------------------------------------
     Section — editorial manifesto. Pure typography, hairline dividers,
     no card containers. Shares only the section primitives (tokens) with
     the rest of the landing via --section-* / --flow-line-bg.
     ------------------------------------------------------------------ */
  #why-casys {
    padding: var(--section-padding-y) 0;
    background: var(--md-sys-color-surface);
    overflow: hidden;
  }

  .container {
    max-width: var(--section-container-max);
    margin: 0 auto;
    padding: 0 var(--section-container-pad-x);
  }

  .section-header {
    margin-bottom: clamp(64px, 10vw, 128px);
    padding-left: 8%;
  }

  .section-kicker {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: var(--section-kicker-size);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--section-kicker-spacing);
    color: var(--md-sys-color-primary);
    margin-bottom: 14px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.03em;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    line-height: 0.98;
  }

  /* ------------------------------------------------------------------
     Manifesto — vertical list of 4 statements separated by hairlines.
     ------------------------------------------------------------------ */
  .manifesto {
    display: flex;
    flex-direction: column;
  }

  .statement-row {
    position: relative;
    display: grid;
    grid-template-columns: 160px 1fr 300px;
    align-items: baseline;
    gap: 32px;
    padding: clamp(48px, 6vw, 72px) clamp(16px, 2vw, 24px);
    margin: 0 clamp(-16px, -2vw, -24px);
    border-top: 1px solid var(--md-sys-color-outline-variant);
    color: inherit;
    text-decoration: none;
    transition: background-color 500ms ease, border-color 500ms ease;
  }

  .statement-row:last-child {
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .statement-row:hover {
    background-color: var(--md-sys-color-surface-container-low);
    border-top-color: var(--md-sys-color-primary);
  }

  .statement-row:hover + .statement-row,
  .statement-row:last-child:hover {
    border-top-color: var(--md-sys-color-primary);
  }

  .statement-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--md-sys-color-primary);
    align-self: start;
    padding-top: 0.4rem;
  }

  .statement-title {
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.9rem, 4.2vw, 3.5rem);
    font-style: italic;
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--md-sys-color-on-surface);
    text-align: center;
  }

  .statement-desc {
    margin: 0;
    max-width: 280px;
    justify-self: end;
    font-size: 0.78rem;
    line-height: 1.65;
    color: var(--md-sys-color-on-surface-variant);
    font-weight: 300;
    transition: color 300ms ease;
  }

  .statement-row:hover .statement-desc {
    color: var(--md-sys-color-on-surface);
  }

  /* ------------------------------------------------------------------
     Founder band — soft footer, aligned with manifesto margin.
     ------------------------------------------------------------------ */
  .founder-band {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(20px, 3vw, 40px);
    align-items: center;
    margin-top: clamp(72px, 10vw, 128px);
    padding-top: clamp(40px, 5vw, 64px);
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .founder-photo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    object-position: 50% 28%;
    box-shadow: inset 0 0 0 1px var(--md-sys-color-outline-variant);
  }

  .founder-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 580px;
  }

  .founder-quote {
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    font-style: italic;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--md-sys-color-on-surface);
  }

  .founder-attribution {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--md-sys-color-on-surface-variant);
  }

  .founder-attribution cite {
    font-style: normal;
    font-weight: 700;
    color: var(--md-sys-color-on-surface);
  }

  .founder-role {
    font-weight: 500;
  }

  .founder-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--md-sys-color-primary);
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: opacity 180ms ease;
    white-space: nowrap;
  }

  .founder-link .material-symbols-rounded {
    font-size: 16px;
    transition: transform 300ms ease;
  }

  .founder-link:hover .material-symbols-rounded {
    transform: translate(3px, -3px);
  }

  /* ------------------------------------------------------------------
     Responsive — collapse 3-column grid to single column under 900px.
     ------------------------------------------------------------------ */
  @media (max-width: 900px) {
    .section-header { padding-left: 0; }

    .statement-row {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 40px clamp(12px, 2vw, 16px);
    }

    .statement-label {
      padding-top: 0;
    }

    .statement-title {
      text-align: left;
    }

    .statement-desc {
      text-align: left;
    }

    .founder-band {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "photo body"
        "link  link";
      gap: 18px 20px;
    }

    .founder-photo { grid-area: photo; width: 80px; height: 80px; }
    .founder-body  { grid-area: body; }
    .founder-link  { grid-area: link; justify-self: end; margin-top: 4px; }
  }

  @media (max-width: 480px) {
    .founder-band {
      grid-template-columns: 1fr;
      grid-template-areas:
        "photo"
        "body"
        "link";
      justify-items: start;
    }
    .founder-link { justify-self: start; }
  }
</style>

<style is:global>
  /* Dark-mode overrides for the manifesto. Typography, accents and hairline
     colors shift to the warm palette; everything else is already handled by
     the MD3 tokens (surface, on-surface, etc.) via data-theme="dark". */
  html[data-theme="dark"] #why-casys {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #why-casys h2,
  html[data-theme="dark"] #why-casys .statement-title,
  html[data-theme="dark"] #why-casys .founder-quote,
  html[data-theme="dark"] #why-casys .founder-attribution cite {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #why-casys .statement-desc,
  html[data-theme="dark"] #why-casys .founder-attribution,
  html[data-theme="dark"] #why-casys .founder-role {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #why-casys .section-kicker,
  html[data-theme="dark"] #why-casys .statement-label,
  html[data-theme="dark"] #why-casys .founder-link {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #why-casys .statement-row,
  html[data-theme="dark"] #why-casys .statement-row:last-child,
  html[data-theme="dark"] #why-casys .founder-band {
    border-color: rgba(255, 184, 111, 0.14);
  }

  html[data-theme="dark"] #why-casys .statement-row:hover {
    background-color: rgba(255, 184, 111, 0.04);
    border-top-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #why-casys .statement-row:hover .statement-desc {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #why-casys .founder-photo {
    box-shadow: inset 0 0 0 1px rgba(255, 184, 111, 0.24);
  }
</style>
