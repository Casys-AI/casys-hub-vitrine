---
import { useTranslations } from '../../i18n';
import { isExternalUrl } from '../../lib/url-utils';

const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).whyCasys;
const leadCard = content.differentiation[0];
const sideCard = content.differentiation[1];
const lowerCards = content.differentiation.slice(2);
const primaryCta = content.bottomLine?.cta?.primary;
const secondaryCta = content.bottomLine?.cta?.secondary;
---

<section id="why-casys">
  <div class="container">
    <header class="section-intro">
      <p class="section-kicker">{content.subtitle}</p>
      <h2>{content.title}</h2>
    </header>

    <div class="bento-grid">
      {leadCard && (
        <article class="feature-card feature-card-lead">
          <div class="feature-shell">
            <div class="lead-copy">
              <span class="material-symbols-rounded card-icon" aria-hidden="true">{leadCard.icon}</span>
              <h3>{leadCard.title}</h3>
              <p class="card-description card-description-large">{leadCard.description}</p>
            </div>

            <div class="lead-trajectory">
              {leadCard.highlights.map((highlight, index) => (
                <div class="trajectory-step">
                  <span class="trajectory-label">{index === 0 ? 'Genesis' : index === 1 ? 'Refinement' : 'Current State'}</span>
                  <p>{highlight}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="lead-visual" aria-hidden="true">
            <div class="visual-ring visual-ring-a"></div>
            <div class="visual-ring visual-ring-b"></div>
            <div class="visual-node visual-node-a"></div>
            <div class="visual-node visual-node-b"></div>
            <div class="visual-node visual-node-c"></div>
            <div class="visual-link visual-link-a"></div>
            <div class="visual-link visual-link-b"></div>
          </div>
        </article>
      )}

      {sideCard && (
        <article class="feature-card feature-card-side">
          <div class="card-copy">
            <span class="material-symbols-rounded card-icon" aria-hidden="true">{sideCard.icon}</span>
            <h3>{sideCard.title}</h3>
            <p class="card-description">{sideCard.description}</p>
          </div>

          <div class="side-footer">
            <span class="side-footer-label">Established</span>
            <span class="side-footer-value">2013+</span>
          </div>
        </article>
      )}

      {lowerCards.map((item, index) => (
        <article class={`feature-card feature-card-small feature-card-small-${index + 1}`}>
          <div class="card-copy">
            <span class="material-symbols-rounded card-icon" aria-hidden="true">{item.icon}</span>
            <h3>{item.title}</h3>
            <p class="card-description">{item.description}</p>
          </div>

          {item.id === 'practical' ? (
            <div class="tag-row">
              {item.highlights.map((highlight) => (
                <span class="tag-chip">{highlight}</span>
              ))}
            </div>
          ) : item.id === 'accessible' && primaryCta ? (
            <a href={primaryCta.url} class="card-action card-action-primary">
              <span>{primaryCta.text}</span>
              <span class="material-symbols-rounded" aria-hidden="true">{primaryCta.icon}</span>
            </a>
          ) : item.id === 'opensource' && secondaryCta ? (
            <a
              href={secondaryCta.url}
              class="card-action card-action-secondary"
              target={isExternalUrl(secondaryCta.url) ? '_blank' : undefined}
              rel={isExternalUrl(secondaryCta.url) ? 'noopener noreferrer' : undefined}
            >
              <span>View repositories</span>
              <span class="material-symbols-rounded" aria-hidden="true">north_east</span>
            </a>
          ) : (
            <ul class="mini-highlights">
              {item.highlights.map((highlight) => (
                <li>
                  <span class="material-symbols-rounded" aria-hidden="true">subdirectory_arrow_right</span>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>

    {content.bottomLine && (
      <div class="signature-band">
        <span class="material-symbols-rounded quote-mark" aria-hidden="true">format_quote</span>
        <blockquote>{content.bottomLine.text}</blockquote>
        <cite>— Casys</cite>

        <div class="signature-actions">
          {primaryCta && (
            <a
              href={primaryCta.url}
              class="cta-primary"
              target={isExternalUrl(primaryCta.url) ? '_blank' : undefined}
              rel={isExternalUrl(primaryCta.url) ? 'noopener noreferrer' : undefined}
            >
              <span class="material-symbols-rounded" aria-hidden="true">{primaryCta.icon}</span>
              <span>{primaryCta.text}</span>
            </a>
          )}
          {secondaryCta && (
            <a
              href={secondaryCta.url}
              class="cta-secondary"
              target={isExternalUrl(secondaryCta.url) ? '_blank' : undefined}
              rel={isExternalUrl(secondaryCta.url) ? 'noopener noreferrer' : undefined}
            >
              <span class="material-symbols-rounded" aria-hidden="true">{secondaryCta.icon}</span>
              <span>{secondaryCta.text}</span>
            </a>
          )}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  #why-casys {
    position: relative;
    padding: 88px 0 96px;
    background:
      radial-gradient(circle at 82% 8%, rgba(157, 132, 183, 0.08), transparent 24%),
      radial-gradient(circle at 8% 0%, rgba(255, 184, 111, 0.1), transparent 26%),
      var(--md-sys-color-surface-container-low);
    overflow: hidden;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  .section-intro {
    max-width: 760px;
    margin-bottom: 42px;
  }

  .section-kicker {
    margin: 0 0 14px;
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
  }

  h2 {
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--md-sys-color-on-surface);
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }

  .feature-card {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    border: 1px solid var(--md-sys-color-outline-variant);
    background: var(--md-sys-color-surface-container);
    min-height: 340px;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.12);
  }

  .feature-card-lead {
    grid-column: span 8;
    min-height: 540px;
    background:
      linear-gradient(180deg, rgba(255, 184, 111, 0.06), transparent 45%),
      linear-gradient(135deg, rgba(255, 184, 111, 0.05), rgba(157, 132, 183, 0.02) 58%, transparent 74%),
      var(--md-sys-color-surface-container-low);
  }

  .feature-card-side {
    grid-column: span 4;
    min-height: 540px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--md-sys-color-surface-container);
  }

  .feature-card-small {
    grid-column: span 4;
    min-height: 380px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .feature-shell,
  .feature-card-side,
  .feature-card-small {
    padding: clamp(28px, 3vw, 42px);
  }

  .feature-shell {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100%;
    gap: 36px;
  }

  .lead-copy,
  .card-copy {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 720px;
  }

  .card-icon {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: var(--md-sys-color-primary);
    background: rgba(255, 184, 111, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 184, 111, 0.08);
  }

  h3 {
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.65rem, 2.4vw, 3rem);
    font-weight: 500;
    line-height: 1.03;
    letter-spacing: -0.025em;
    color: var(--md-sys-color-on-surface);
  }

  .feature-card-side h3,
  .feature-card-small h3 {
    font-size: clamp(1.35rem, 1.9vw, 2rem);
  }

  .card-description {
    margin: 0;
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.72;
    color: var(--md-sys-color-on-surface-variant);
  }

  .card-description-large {
    font-size: 1.08rem;
    max-width: 34rem;
  }

  .lead-trajectory {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    position: relative;
    z-index: 2;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 184, 111, 0.12);
  }

  .trajectory-step {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .trajectory-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
  }

  .trajectory-step p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--md-sys-color-on-surface);
  }

  .lead-visual {
    position: absolute;
    inset: auto -8% -10% auto;
    width: 52%;
    height: 88%;
    pointer-events: none;
    opacity: 0.78;
  }

  .visual-ring,
  .visual-node,
  .visual-link {
    position: absolute;
  }

  .visual-ring {
    border-radius: 999px;
    border: 1px solid rgba(245, 240, 234, 0.08);
  }

  .visual-ring-a {
    inset: 12% 6% 14% 18%;
  }

  .visual-ring-b {
    inset: 28% 16% 24% 28%;
    border-color: rgba(255, 184, 111, 0.1);
  }

  .visual-node {
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: rgba(255, 184, 111, 0.9);
    box-shadow: 0 0 0 10px rgba(255, 184, 111, 0.07);
  }

  .visual-node-a { top: 22%; right: 38%; }
  .visual-node-b { top: 52%; right: 20%; }
  .visual-node-c { top: 68%; right: 48%; }

  .visual-link {
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 184, 111, 0), rgba(255, 184, 111, 0.28), rgba(245, 240, 234, 0));
    transform-origin: left center;
  }

  .visual-link-a {
    top: 28%;
    right: 26%;
    width: 34%;
    transform: rotate(26deg);
  }

  .visual-link-b {
    top: 58%;
    right: 28%;
    width: 26%;
    transform: rotate(-28deg);
  }

  .side-footer {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 20px;
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .side-footer-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
  }

  .side-footer-value {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.6rem;
    color: var(--md-sys-color-on-surface);
  }

  .mini-highlights {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }

  .mini-highlights li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.95rem;
    line-height: 1.56;
    color: var(--md-sys-color-on-surface-variant);
  }

  .mini-highlights .material-symbols-rounded {
    margin-top: 1px;
    flex-shrink: 0;
    font-size: 17px;
    color: var(--md-sys-color-primary);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid var(--md-sys-color-outline-variant);
    background: var(--md-sys-color-surface-container-lowest);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface-variant);
  }

  .card-action {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: fit-content;
    min-height: 48px;
    margin-top: 22px;
    padding: 0 16px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .card-action:hover {
    transform: translateY(-1px);
  }

  .card-action-primary {
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
  }

  .card-action-secondary {
    border: 1px solid var(--md-sys-color-outline-variant);
    color: var(--md-sys-color-on-surface);
    background: transparent;
  }

  .signature-band {
    margin-top: 28px;
    padding: clamp(34px, 4vw, 58px);
    border-radius: 30px;
    border: 1px solid var(--md-sys-color-outline-variant);
    background:
      linear-gradient(180deg, rgba(255, 184, 111, 0.03), transparent 36%),
      var(--md-sys-color-surface-container-lowest);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }

  .quote-mark {
    font-size: 3rem;
    color: var(--md-sys-color-primary);
    opacity: 0.34;
  }

  blockquote {
    margin: 0;
    max-width: 900px;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.55rem, 3vw, 2.8rem);
    line-height: 1.18;
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--md-sys-color-on-surface);
  }

  cite {
    font-style: normal;
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
  }

  .signature-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    font-family: 'Manrope', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .cta-primary {
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
  }

  .cta-secondary {
    color: var(--md-sys-color-on-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    background: transparent;
  }

  .cta-primary:hover,
  .cta-secondary:hover {
    transform: translateY(-1px);
  }

  @media (max-width: 960px) {
    .feature-card-lead,
    .feature-card-side,
    .feature-card-small {
      grid-column: 1 / -1;
      min-height: auto;
    }

    .lead-trajectory {
      grid-template-columns: 1fr;
    }

    .lead-visual {
      width: 50%;
      height: 46%;
      inset: auto -2% -4% auto;
    }
  }

  @media (max-width: 640px) {
    #why-casys {
      padding: 72px 0 80px;
    }

    .bento-grid {
      gap: 18px;
    }

    .feature-shell,
    .feature-card-side,
    .feature-card-small,
    .signature-band {
      padding: 24px;
    }

    .section-kicker,
    .trajectory-label,
    .side-footer-label,
    cite {
      letter-spacing: 0.2em;
    }

    .card-description,
    .card-description-large,
    .mini-highlights li,
    .trajectory-step p {
      font-size: 0.92rem;
    }

    .lead-visual {
      display: none;
    }

    .signature-actions {
      width: 100%;
      flex-direction: column;
    }

    .cta-primary,
    .cta-secondary,
    .card-action {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<style is:global>
  html[data-theme='dark'] #why-casys {
    background:
      radial-gradient(circle at 82% 8%, rgba(157, 132, 183, 0.08), transparent 24%),
      radial-gradient(circle at 8% 0%, rgba(255, 184, 111, 0.1), transparent 26%),
      var(--casys-warm-background);
  }

  html[data-theme='dark'] #why-casys .feature-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme='dark'] #why-casys .feature-card-lead {
    background:
      linear-gradient(180deg, rgba(255, 184, 111, 0.06), transparent 45%),
      linear-gradient(135deg, rgba(255, 184, 111, 0.05), rgba(157, 132, 183, 0.03) 58%, transparent 74%),
      var(--casys-warm-surface);
  }

  html[data-theme='dark'] #why-casys h2,
  html[data-theme='dark'] #why-casys h3,
  html[data-theme='dark'] #why-casys blockquote,
  html[data-theme='dark'] #why-casys .trajectory-step p,
  html[data-theme='dark'] #why-casys .side-footer-value {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme='dark'] #why-casys .section-kicker,
  html[data-theme='dark'] #why-casys .trajectory-label,
  html[data-theme='dark'] #why-casys .side-footer-label,
  html[data-theme='dark'] #why-casys .card-icon,
  html[data-theme='dark'] #why-casys .mini-highlights .material-symbols-rounded,
  html[data-theme='dark'] #why-casys .quote-mark,
  html[data-theme='dark'] #why-casys cite {
    color: var(--casys-warm-accent);
  }

  html[data-theme='dark'] #why-casys .card-icon {
    background: rgba(255, 184, 111, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 184, 111, 0.08);
  }

  html[data-theme='dark'] #why-casys .card-description,
  html[data-theme='dark'] #why-casys .mini-highlights li,
  html[data-theme='dark'] #why-casys .tag-chip,
  html[data-theme='dark'] #why-casys .cta-secondary,
  html[data-theme='dark'] #why-casys .card-action-secondary {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme='dark'] #why-casys .side-footer,
  html[data-theme='dark'] #why-casys .lead-trajectory,
  html[data-theme='dark'] #why-casys .tag-chip,
  html[data-theme='dark'] #why-casys .cta-secondary,
  html[data-theme='dark'] #why-casys .card-action-secondary,
  html[data-theme='dark'] #why-casys .signature-band {
    border-color: rgba(255, 184, 111, 0.12);
  }

  html[data-theme='dark'] #why-casys .tag-chip {
    background: #100f0d;
  }

  html[data-theme='dark'] #why-casys .signature-band {
    background:
      linear-gradient(180deg, rgba(255, 184, 111, 0.04), transparent 36%),
      #100f0d;
  }

  html[data-theme='dark'] #why-casys .cta-primary,
  html[data-theme='dark'] #why-casys .card-action-primary {
    background: var(--casys-warm-accent);
    color: var(--casys-warm-background);
  }

  html[data-theme='dark'] #why-casys .feature-card:hover,
  html[data-theme='dark'] #why-casys .cta-secondary:hover,
  html[data-theme='dark'] #why-casys .card-action-secondary:hover {
    border-color: var(--casys-warm-accent);
    background: rgba(255, 184, 111, 0.04);
  }
</style>
