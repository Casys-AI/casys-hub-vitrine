---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const localePrefix = locale === 'en' ? '' : `/${locale}`;

const title = locale === 'fr' ? 'Notre stack open-source'
  : locale === 'zh' ? '我们的开源技术栈'
  : locale === 'zh-TW' ? '我們的開源技術棧'
  : 'Our open-source stack';
const kicker = 'Infrastructure';
const subtitle = locale === 'fr' ? 'Trois packages TypeScript pour passer du prototype à la production.'
  : locale === 'zh' ? '三个 TypeScript 包，从原型到生产。'
  : locale === 'zh-TW' ? '三個 TypeScript 套件，從原型到生產。'
  : 'Three TypeScript packages to go from prototype to production.';
const cta = locale === 'fr' ? 'Explorer la plateforme'
  : locale === 'zh' ? '探索平台'
  : locale === 'zh-TW' ? '探索平台'
  : 'Explore the platform';

const packages = [
  {
    step: '01',
    label: 'Build',
    name: '@casys/mcp-server',
    tagline: locale === 'fr' ? 'Le Hono pour MCP.' : 'The Hono for MCP.',
    desc: locale === 'fr'
      ? 'Middleware composable, OAuth2, double transport. Prêt pour la production dès le premier jour.'
      : locale === 'zh' ? '可组合中间件、OAuth2、双传输。从第一天起即可用于生产。'
      : locale === 'zh-TW' ? '可組合中間件、OAuth2、雙傳輸。從第一天起即可用於生產。'
      : 'Composable middleware, OAuth2, dual transport. Production-ready from day one.',
    icon: 'terminal',
  },
  {
    step: '02',
    label: 'Connect',
    name: '@casys/mcp-bridge',
    tagline: locale === 'fr' ? 'MCP vers Telegram Mini Apps.' : 'Turn MCP tools into Telegram Mini Apps.',
    desc: locale === 'fr'
      ? 'Couche de transformation protocolaire. Déployez des outils cross-platform instantanément.'
      : locale === 'zh' ? '协议转换层。即时部署跨平台工具。'
      : locale === 'zh-TW' ? '協議轉換層。即時部署跨平台工具。'
      : 'Protocol transformation layer. Deploy instant, cross-platform tools.',
    icon: 'hub',
  },
  {
    step: '03',
    label: 'Compose',
    name: '@casys/mcp-compose',
    tagline: locale === 'fr' ? 'Collecte, compose et synchronise.' : 'Collect, compose, and sync MCP UIs.',
    desc: locale === 'fr'
      ? 'Orchestrez des dashboards multi-serveurs avec synchronisation d\'état unifiée.'
      : locale === 'zh' ? '通过统一状态同步编排多服务器仪表板。'
      : locale === 'zh-TW' ? '透過統一狀態同步編排多伺服器儀表板。'
      : 'Orchestrate multi-server dashboards with unified state synchronization.',
    icon: 'auto_awesome_motion',
  },
];
---

<section id="platform-preview" class="reveal">
  <div class="container">
    <header class="section-header">
      <span class="section-kicker">{kicker}</span>
      <h2>{title}</h2>
    </header>

    <div class="stack-flow">
      <div class="flow-line" aria-hidden="true"></div>

      {packages.map((pkg, i) => (
        <a
          href={`${localePrefix}/mcp-platform#${pkg.label.toLowerCase()}`}
          class={`stack-card card-${i}`}
        >
          <span class="card-watermark" aria-hidden="true">{pkg.step}</span>
          <div class="card-head">
            <span class="material-symbols-rounded card-icon">{pkg.icon}</span>
            <span class="card-label">{pkg.label}</span>
          </div>
          <code class="card-name">{pkg.name}</code>
          <p class="card-tagline">{pkg.tagline}</p>
          <p class="card-desc">{pkg.desc}</p>
        </a>
      ))}
    </div>

    <div class="cta-row">
      <a href={`${localePrefix}/mcp-platform`} class="platform-cta">
        <span>{cta}</span>
        <span class="material-symbols-rounded">arrow_forward</span>
      </a>
    </div>
  </div>
</section>

<style>
  #platform-preview {
    padding: 88px 0 96px;
    background: var(--md-sys-color-surface);
    overflow: hidden;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header — editorial offset */
  .section-header {
    margin-bottom: 56px;
    padding-left: 8%;
  }

  .section-kicker {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--md-sys-color-on-surface-variant);
    margin-bottom: 14px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 600;
    font-style: italic;
    letter-spacing: -0.03em;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    line-height: 1.1;
  }

  /* Stack flow — asymmetric layout */
  .stack-flow {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
    margin-bottom: 56px;
  }

  .flow-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--md-sys-color-outline-variant), transparent);
    z-index: 0;
    pointer-events: none;
  }

  /* Cards */
  .stack-card {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 32px 28px;
    border-radius: 14px;
    background: var(--md-sys-color-surface-container-lowest);
    text-decoration: none;
    color: inherit;
    transition: background 0.3s ease;
  }

  .stack-card:hover {
    background: var(--md-sys-color-surface-container);
  }

  /* Asymmetric vertical offsets */
  .card-0 { transform: translateY(-16px); }
  .card-1 { transform: translateY(24px); background: var(--md-sys-color-surface-container-low); }
  .card-2 { transform: translateY(-8px); }

  .card-1:hover {
    background: var(--md-sys-color-surface-container);
  }

  /* Watermark numbers */
  .card-watermark {
    position: absolute;
    top: -32px;
    left: -4px;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 8rem;
    font-style: italic;
    font-weight: 800;
    color: var(--md-sys-color-primary);
    opacity: 0.04;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .card-icon {
    font-size: 22px;
    color: var(--md-sys-color-primary);
  }

  .card-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--md-sys-color-on-surface-variant);
  }

  .card-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--md-sys-color-primary);
  }

  .card-tagline {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-style: italic;
    line-height: 1.3;
    color: var(--md-sys-color-on-surface);
    margin: 0;
  }

  .card-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .stack-card:hover .card-desc {
    opacity: 1;
  }

  /* CTA — right-aligned */
  .cta-row {
    display: flex;
    justify-content: flex-end;
  }

  .platform-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    border-radius: 10px;
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: opacity 0.15s ease;
  }

  .platform-cta:hover {
    opacity: 0.88;
  }

  .platform-cta .material-symbols-rounded {
    font-size: 20px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .stack-flow {
      grid-template-columns: 1fr;
      max-width: 480px;
      gap: 16px;
    }

    .card-0, .card-1, .card-2 {
      transform: none;
    }

    .flow-line { display: none; }

    .section-header { padding-left: 0; }

    .cta-row { justify-content: center; }
  }

  @media (max-width: 768px) {
    #platform-preview {
      padding: 64px 0 72px;
    }

    .section-header { margin-bottom: 40px; }
  }
</style>

<style is:global>
  html[data-theme="dark"] #platform-preview {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #platform-preview .section-kicker {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #platform-preview h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #platform-preview .flow-line {
    background: linear-gradient(to right, transparent, rgba(255, 184, 111, 0.15), transparent);
  }

  html[data-theme="dark"] #platform-preview .stack-card {
    background: #1d1b1a;
  }

  html[data-theme="dark"] #platform-preview .stack-card:hover {
    background: #211f1e;
  }

  html[data-theme="dark"] #platform-preview .card-1 {
    background: #211f1e;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  html[data-theme="dark"] #platform-preview .card-1:hover {
    background: #2b2a28;
  }

  html[data-theme="dark"] #platform-preview .card-watermark {
    color: #FFB86F;
    opacity: 0.04;
  }

  html[data-theme="dark"] #platform-preview .card-icon {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview .card-label {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #platform-preview .card-name {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview .card-tagline {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #platform-preview .card-desc {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #platform-preview .platform-cta {
    background: var(--casys-warm-accent);
    color: #0a0908;
    box-shadow: 0 0 30px rgba(255, 184, 111, 0.15);
  }
</style>
