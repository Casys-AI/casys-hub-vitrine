---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const localePrefix = locale === 'en' ? '' : `/${locale}`;

const title = locale === 'fr' ? 'Notre stack open-source' : 'Our open-source stack';
const kicker = locale === 'fr' ? 'Infrastructure' : 'Infrastructure';
const subtitle = locale === 'fr'
  ? 'Trois packages TypeScript pour passer du prototype à la production.'
  : 'Three TypeScript packages to go from prototype to production.';
const cta = locale === 'fr' ? 'Explorer la plateforme' : 'Explore the platform';

const packages = [
  {
    step: '01',
    label: 'Build',
    name: '@casys/mcp-server',
    desc: locale === 'fr'
      ? 'Middleware composable, OAuth2, double transport. Le Hono pour MCP.'
      : 'Composable middleware, OAuth2, dual transport. The Hono for MCP.',
    icon: 'dns',
  },
  {
    step: '02',
    label: 'Connect',
    name: '@casys/mcp-bridge',
    desc: locale === 'fr'
      ? 'Transforme vos outils MCP en Telegram Mini Apps et LINE LIFF.'
      : 'Turn MCP tools into Telegram Mini Apps and LINE LIFF.',
    icon: 'cable',
  },
  {
    step: '03',
    label: 'Compose',
    name: '@casys/mcp-compose',
    desc: locale === 'fr'
      ? 'Collecte, compose et synchronise des UIs MCP en dashboards.'
      : 'Collect, compose, and sync MCP UIs into dashboards.',
    icon: 'dashboard_customize',
  },
];
---

<section id="platform-preview" class="reveal">
  <div class="container">
    <header class="section-header">
      <span class="section-kicker">{kicker}</span>
      <h2>{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </header>

    <div class="stack-grid">
      {packages.map((pkg) => (
        <a href={`${localePrefix}/mcp-platform#${pkg.label.toLowerCase()}`} class="stack-card">
          <div class="card-top">
            <span class="card-step">{pkg.step}</span>
            <span class="card-label">{pkg.label}</span>
          </div>
          <div class="card-body">
            <span class="material-symbols-rounded card-icon">{pkg.icon}</span>
            <h3>{pkg.name}</h3>
            <p>{pkg.desc}</p>
          </div>
          <span class="material-symbols-rounded card-arrow">arrow_forward</span>
        </a>
      ))}
    </div>

    <div class="cta-row">
      <a href={`${localePrefix}/mcp-platform`} class="platform-cta">
        <span>{cta}</span>
        <span class="material-symbols-rounded">arrow_forward</span>
      </a>
    </div>
  </div>
</section>

<style>
  #platform-preview {
    padding: 80px 0 88px;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-header {
    margin-bottom: 40px;
  }

  .section-kicker {
    display: block;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--md-sys-color-primary);
    margin-bottom: 12px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
    max-width: 520px;
  }

  /* Stack grid */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .stack-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    border-radius: 16px;
    background: var(--md-sys-color-surface-container-lowest);
    border: 1px solid var(--md-sys-color-outline-variant);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .stack-card:hover {
    border-color: var(--md-sys-color-primary);
    transform: translateY(-3px);
  }

  .card-top {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .card-step {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 700;
    color: var(--md-sys-color-primary);
    opacity: 0.5;
    line-height: 1;
  }

  .card-label {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--md-sys-color-primary);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .card-icon {
    font-size: 24px;
    color: var(--md-sys-color-primary);
  }

  .stack-card h3 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 600;
    margin: 0;
    color: var(--md-sys-color-on-surface);
  }

  .stack-card p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--md-sys-color-on-surface-variant);
  }

  .card-arrow {
    font-size: 18px;
    color: var(--md-sys-color-primary);
    align-self: flex-end;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .stack-card:hover .card-arrow {
    opacity: 1;
  }

  /* CTA */
  .cta-row {
    display: flex;
    justify-content: center;
  }

  .platform-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 10px;
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: opacity 0.15s ease;
  }

  .platform-cta:hover {
    opacity: 0.88;
  }

  .platform-cta .material-symbols-rounded {
    font-size: 18px;
  }

  @media (max-width: 900px) {
    .stack-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
    }
  }

  @media (max-width: 768px) {
    #platform-preview {
      padding: 56px 0 64px;
    }
  }
</style>

<style is:global>
  html[data-theme="dark"] #platform-preview {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #platform-preview .section-kicker {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #platform-preview .section-subtitle {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #platform-preview .stack-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #platform-preview .stack-card:hover {
    border-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview .card-step {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview .card-label {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview .card-icon {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview .stack-card h3 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #platform-preview .stack-card p {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #platform-preview .card-arrow {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #platform-preview .platform-cta {
    background: var(--casys-warm-accent);
    color: #0a0908;
  }
</style>
