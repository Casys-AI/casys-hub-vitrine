---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).faq;

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": content.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<section id="faq">
  <div class="container">
    <!-- Editorial Header — left-aligned, asymmetric -->
    <div class="section-header">
      <h2>{content.title}</h2>
      <p class="section-subtitle">{content.subtitle}</p>
    </div>

    <!-- Category Filter Pills -->
    <div class="category-filter">
      <button class="category-btn active" data-category="all">
        <span>{content.allLabel}</span>
      </button>
      {content.categories.map((category) => (
        <button class="category-btn" data-category={category}>
          <span>{category}</span>
        </button>
      ))}
    </div>

    <!-- FAQ Accordion List -->
    <div class="faq-list">
      {content.faqs.map((faq) => (
        <details class="faq-item" data-category={faq.category}>
          <summary class="faq-question">
            <div class="question-content">
              <span class="category-tag">{faq.category}</span>
              <span class="question-text">{faq.q}</span>
            </div>
            <span class="material-symbols-rounded expand-icon">expand_more</span>
          </summary>
          <div class="faq-answer-wrap">
            <p class="faq-answer">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

    {content.closingCta && (
      <div class="faq-closing">
        <p class="faq-closing-prompt">{content.closingCta.prompt}</p>
        <a href={content.closingCta.url} class="faq-closing-cta">
          <span class="material-symbols-rounded" aria-hidden="true">{content.closingCta.icon}</span>
          <span>{content.closingCta.ctaLabel}</span>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  /* ========================================
     FAQ — Premium Editorial Redesign
     Inspired by Stitch "Obsidian Archivist"
     Light: MD3 tokens
     Dark: --casys-warm-* tokens (global styles)
     ======================================== */

  section {
    padding: 72px 0;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Left-aligned editorial header */
  .section-header {
    text-align: left;
    margin-bottom: 56px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.75rem;
    font-weight: 600;
    font-style: italic;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.7;
    max-width: 520px;
  }

  /* Category Filter — rounded pills */
  .category-filter {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .category-btn {
    padding: 8px 20px;
    background: var(--md-sys-color-surface-container);
    color: var(--md-sys-color-on-surface-variant);
    border: none;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background 250ms ease, color 250ms ease;
    font-family: inherit;
  }

  .category-btn:hover {
    background: var(--md-sys-color-surface-container-high);
    color: var(--md-sys-color-primary);
  }

  .category-btn:focus-visible {
    outline: 2px solid var(--md-sys-color-primary);
    outline-offset: 3px;
  }

  .category-btn.active {
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
  }

  /* FAQ List — tonal depth, no borders */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: var(--md-sys-color-surface-container-low);
    border: none;
    border-radius: 16px;
    padding: 24px 28px;
    cursor: pointer;
    transition: background 300ms ease, box-shadow 300ms ease;
  }

  .faq-item:hover {
    background: var(--md-sys-color-surface-container);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.04);
  }

  .faq-item.hidden {
    display: none;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question:focus-visible {
    outline: 2px solid var(--md-sys-color-primary);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .question-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .category-tag {
    display: inline-block;
    padding: 3px 10px;
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    width: fit-content;
  }

  .question-text {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    transition: color 250ms ease;
  }

  .faq-item:hover .question-text {
    color: var(--md-sys-color-primary);
  }

  .expand-icon {
    transition: transform 300ms ease;
    font-size: 24px;
    color: var(--md-sys-color-primary);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .faq-item[open] .expand-icon {
    transform: rotate(180deg);
  }

  .faq-answer-wrap {
    padding-top: 16px;
    margin-top: 4px;
  }

  .faq-answer {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.8;
    margin: 0;
    max-width: 680px;
  }

  /* FAQ closing CTA */
  .faq-closing {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .faq-closing-prompt {
    margin: 0;
    font-size: 1rem;
    color: var(--md-sys-color-on-surface-variant);
  }

  .faq-closing-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 999px;
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
    text-decoration: none;
    font-size: 0.93rem;
    font-weight: 600;
    transition: transform 180ms ease, filter 180ms ease;
  }

  .faq-closing-cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
  }

  .faq-closing-cta .material-symbols-rounded {
    font-size: 20px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    section {
      padding: 40px 0;
    }

    h2 {
      font-size: 2rem;
    }

    .section-header {
      margin-bottom: 36px;
    }

    .category-filter {
      margin-bottom: 28px;
      gap: 8px;
    }

    .category-btn {
      padding: 6px 14px;
      font-size: 0.7rem;
    }

    .faq-item {
      padding: 18px 20px;
      border-radius: 12px;
    }

    .question-text {
      font-size: 1rem;
    }

    .faq-answer {
      font-size: 0.9rem;
    }
  }
</style>

<style is:global>
  /* ========================================
     FAQ — DARK MODE
     Warm orange palette via --casys-warm-*
     Tonal depth: no borders, background shifts
     ======================================== */

  html[data-theme="dark"] #faq {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #faq h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #faq .section-subtitle {
    color: var(--casys-warm-text-muted);
  }

  /* Category Buttons — borderless, tonal */
  html[data-theme="dark"] #faq .category-btn {
    background: var(--casys-warm-surface);
    color: var(--casys-warm-text-muted);
    border: none;
  }

  html[data-theme="dark"] #faq .category-btn:hover {
    background: rgba(255, 184, 111, 0.08);
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #faq .category-btn:focus-visible,
  html[data-theme="dark"] #faq .faq-question:focus-visible {
    outline-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #faq .category-btn.active {
    background: var(--casys-warm-accent);
    color: #1a1815;
  }

  /* FAQ Items — glassmorphic hover */
  html[data-theme="dark"] #faq .faq-item {
    background: var(--casys-warm-surface);
    border: none;
  }

  html[data-theme="dark"] #faq .faq-item:hover {
    background: rgba(33, 31, 30, 0.6);
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(255, 184, 111, 0.03);
  }

  html[data-theme="dark"] #faq .question-text {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #faq .faq-item:hover .question-text {
    color: var(--casys-warm-accent);
  }

  /* Category tags — mauve accent */
  html[data-theme="dark"] #faq .category-tag {
    background: rgba(157, 132, 183, 0.15);
    color: #d7bcf2;
  }

  html[data-theme="dark"] #faq .expand-icon {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #faq .faq-answer {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #faq .faq-closing-prompt {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #faq .faq-closing-cta {
    background: var(--casys-warm-accent);
    color: #1a1815;
  }
</style>

<script>
  const categoryButtons = document.querySelectorAll('#faq .category-btn');
  const faqItems = document.querySelectorAll('#faq .faq-item');

  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const selectedCategory = button.getAttribute('data-category');

      categoryButtons.forEach((btn) => btn.classList.remove('active'));
      button.classList.add('active');

      faqItems.forEach((item) => {
        const itemCategory = item.getAttribute('data-category');

        if (selectedCategory === 'all' || itemCategory === selectedCategory) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });
    });
  });
</script>
