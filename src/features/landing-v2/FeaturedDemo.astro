---
import { useTranslations } from '../../i18n';

const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).featuredDemo;

function isExternalUrl(url: string): boolean {
  return /^https?:\/\//.test(url);
}
---

<section id="featured-demo">
  <div class="container">
    <div class="section-header">
      <h2>{content.title}</h2>
      <p class="section-subtitle">{content.subtitle}</p>
    </div>

    <div class="demo-grid">
      <div class="video-card">
        <video controls playsinline preload="metadata">
          <source src={content.video.src} type="video/mp4" />
        </video>
        <p class="video-caption">{content.video.caption}</p>
        <p class="note">{content.note}</p>
      </div>

      <div class="demo-copy">
        <span class="eyebrow">{content.eyebrow}</span>
        <h3>{content.name}</h3>
        <p class="tagline">{content.tagline}</p>
        <p class="description">{content.description}</p>

        <div class="bullet-list">
          {content.bullets.map((bullet) => (
            <div class="bullet-item">
              <span class="material-symbols-rounded">check_circle</span>
              <span>{bullet}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding: 56px 0;
    background: var(--md-sys-color-surface-container-lowest);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-header {
    text-align: left;
    margin-bottom: 40px;
    max-width: 680px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  .demo-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 32px;
    align-items: start;
  }

  .video-card,
  .demo-copy {
    background: var(--md-sys-color-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 20px;
    transition: transform 280ms cubic-bezier(0.2, 0, 0, 1), box-shadow 280ms cubic-bezier(0.2, 0, 0, 1);
  }

  .video-card:hover,
  .demo-copy:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .video-card {
    padding: 18px;
    overflow: hidden;
  }

  video {
    width: 100%;
    display: block;
    border-radius: 12px;
    background: #000;
  }

  .video-caption {
    font-size: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 14px 4px 0;
    line-height: 1.5;
  }

  .demo-copy {
    padding: 28px 30px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    border-left: 4px solid var(--md-sys-color-primary);
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--md-sys-color-primary);
  }

  h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    margin: 0;
    color: var(--md-sys-color-on-surface);
    letter-spacing: -0.02em;
  }

  .tagline {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--md-sys-color-primary);
    margin: -6px 0 0;
  }

  .description,
  .note {
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
  }

  .bullet-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bullet-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    color: var(--md-sys-color-on-surface);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .bullet-item .material-symbols-rounded {
    font-size: 18px;
    color: var(--md-sys-color-primary);
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    .demo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  /* Featured Demo — Dark Mode (warm orange palette) */
  html[data-theme="dark"] #featured-demo {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #featured-demo h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #featured-demo .section-subtitle {
    color: var(--casys-warm-text-secondary);
  }

  /* Cards */
  html[data-theme="dark"] #featured-demo .video-card,
  html[data-theme="dark"] #featured-demo .demo-copy {
    background: var(--casys-warm-surface);
    border-color: var(--casys-warm-border-accent);
  }

  html[data-theme="dark"] #featured-demo .demo-copy {
    border-left-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #featured-demo .video-caption {
    color: var(--casys-warm-text-muted);
  }

  /* Text */
  html[data-theme="dark"] #featured-demo .eyebrow {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #featured-demo h3 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #featured-demo .tagline {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #featured-demo .description,
  html[data-theme="dark"] #featured-demo .note {
    color: var(--casys-warm-text-secondary);
  }

  /* Bullets */
  html[data-theme="dark"] #featured-demo .bullet-item {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #featured-demo .bullet-item .material-symbols-rounded {
    color: var(--casys-warm-accent);
  }

</style>
