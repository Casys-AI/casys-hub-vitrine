---
const jsrSvg = `<svg width="18" height="18" viewBox="0 -3 64 64" fill="none" aria-hidden="true"><path d="M 0,21.846 H 9.846 V 12 h 34.462 v 4.923 H 64 V 36.616 H 54.155 V 46.462 H 19.693 V 41.539 H 0" fill="#083344"/><g fill="#f7df1e" transform="matrix(4.923,0,0,4.923,0,12)"><path d="M 1,3 H 2 V 4 H 3 V 1 H 4 V 5 H 1"/><path d="M 5,1 H 8 V 2 H 6 V 3 H 8 V 6 H 5 V 5 H 7 V 4 H 5"/><path d="m 9,2 h 3 V 4 H 11 V 3 H 10 V 6 H 9"/></g></svg>`;

const npmSvg = `<svg width="18" height="18" viewBox="0 0 780 250" aria-hidden="true"><path fill="#CB3837" d="M240,250h100v-50h100V0H240V250z M340,50h50v100h-50V50z M480,0v200h100V50h50v150h50V50h50v150h50V0H480z M0,200h100V50h50v150h50V0H0V200z"/></svg>`;

const packages = [
  {
    name: '@casys/mcp-server',
    jsr: 'deno add jsr:@casys/mcp-server',
    npm: 'npx jsr add @casys/mcp-server',
  },
  {
    name: '@casys/mcp-bridge',
    jsr: 'deno add jsr:@casys/mcp-bridge',
    npm: 'npx jsr add @casys/mcp-bridge',
  },
  {
    name: '@casys/mcp-compose',
    jsr: 'deno add jsr:@casys/mcp-compose',
    npm: 'npx jsr add @casys/mcp-compose',
  },
];
---

<section id="install">
  <div class="container">
    <h2>Start building</h2>

    <div class="install-grid">
      {packages.map((pkg) => (
        <div class="install-card">
          <span class="pkg-name">{pkg.name}</span>
          <div class="cmd-row">
            <span class="cmd-logo" set:html={jsrSvg} />
            <code>{pkg.jsr}</code>
          </div>
          <div class="cmd-row">
            <span class="cmd-logo" set:html={npmSvg} />
            <code>{pkg.npm}</code>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #install {
    padding: 80px 0 88px;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 36px;
  }

  .install-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .install-card {
    padding: 24px 20px;
    border-radius: 14px;
    background: var(--md-sys-color-surface-container-lowest);
    border: 1px solid var(--md-sys-color-outline-variant);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 150ms ease;
  }

  .install-card:hover {
    border-color: var(--md-sys-color-primary);
  }

  .pkg-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    margin-bottom: 4px;
  }

  .cmd-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: var(--md-sys-color-surface-container);
    border-radius: 8px;
    overflow: hidden;
  }

  .cmd-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    width: 18px;
    height: 18px;
  }

  code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    color: var(--md-sys-color-on-surface);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 900px) {
    .install-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
    }
  }

  @media (max-width: 768px) {
    #install {
      padding: 56px 0 64px;
    }
  }
</style>

<style is:global>
  html[data-theme="dark"] #install {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #install h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #install .install-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #install .install-card:hover {
    border-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #install .pkg-name {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #install .cmd-row {
    background: #0d0c0a;
  }

  html[data-theme="dark"] #install code {
    color: var(--casys-warm-text-primary);
  }
</style>
