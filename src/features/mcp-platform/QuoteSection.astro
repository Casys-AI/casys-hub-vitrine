---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).mcpPlatform;
---

<section id="platform-quote">
  <div class="container">
    <div class="quote-inner">
      <div class="quote-line" aria-hidden="true"></div>
      <blockquote>{t.quote}</blockquote>
    </div>
  </div>
</section>

<style>
  #platform-quote {
    padding: 100px 0;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .quote-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    max-width: 720px;
    margin: 0 auto;
  }

  .quote-line {
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: var(--md-sys-color-primary);
  }

  blockquote {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-style: italic;
    line-height: 1.5;
    margin: 0;
    color: var(--md-sys-color-on-surface);
    letter-spacing: -0.01em;
  }
</style>

<style is:global>
  html[data-theme="dark"] #platform-quote {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #platform-quote .quote-line {
    background: #FFB86F;
  }

  html[data-theme="dark"] #platform-quote blockquote {
    color: var(--casys-warm-text-primary);
  }
</style>
